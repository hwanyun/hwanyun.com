---
import { getCollection } from "astro:content"

const { filter = "", current = "home" } = Astro.props

// size → 패킹 weight (셀 비중). 클수록 넓은 면적을 차지한다.
const WEIGHT: Record<string, number> = { "1col": 1, "2col": 1.7, "3col": 2.6 }

let works = await getCollection("works", ({ data }) => !data.draft)
if (filter) works = works.filter((w) => w.data.category === filter)
works.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))

const nav = [
  { label: "Works", href: "/works", key: "works" },
  { label: "Sound", href: "/sound", key: "sound" },
  { label: "Bio", href: "/cv", key: "bio" },
  { label: "Contact", href: "/contact", key: "contact" },
]
---

<div id="packed">
  <!-- 메뉴 = 좌상단 고정 오버레이 (트리맵에서 제외, 왜곡·잘림 없음) -->
  <nav class="home-menu">
    <div class="name"><a href="/">HWANYUN</a></div>
    {
      nav.map((n) => (
        <a href={n.href} class={current === n.key ? "current" : ""}>
          {n.label}
        </a>
      ))
    }
    <input id="search" type="search" placeholder="Search" autocomplete="off" />
  </nav>

  <!-- 직사각형 그리드 (메뉴 컬럼 오른쪽, 좌우·상하 여백 안쪽) -->
  <div class="grid">
    {
      works.map((w) => (
        <a
          class="tile card"
          href={`/works/${w.slug}`}
          data-weight={WEIGHT[w.data.size] ?? 1.7}
          data-search={`${w.data.title} ${w.data.year} ${w.data.medium}`.toLowerCase()}
        >
          <div class="thumb">
            {w.data.thumb ? <img src={w.data.thumb} alt={w.data.title} /> : <div class="ph" />}
          </div>
          <div class="cap">
            <span class="t">{w.data.title}</span>
            {w.data.year ? <span class="y"> ({w.data.year})</span> : ""}
          </div>
        </a>
      ))
    }
    <div id="noresult" hidden>No results.</div>
  </div>
</div>

<script is:inline>
  ;(function () {
    var c = document.getElementById("packed")
    if (!c) return
    var grid = c.querySelector(".grid")
    var input = document.getElementById("search")
    var none = document.getElementById("noresult")
    var tiles = Array.prototype.slice.call(grid.querySelectorAll(".tile"))
    var SHARE = 0.4 // hover 시 해당 셀이 차지할 목표 면적 비율

    // 각 셀을 leaf 객체로 (DOM 순서 = 패킹 순서)
    var leaves = tiles.map(function (el) {
      return {
        el: el,
        base: parseFloat(el.getAttribute("data-weight")) || 1,
        w: 0,
        menu: el.hasAttribute("data-menu"),
      }
    })

    function desktop() {
      return window.matchMedia("(min-width: 701px)").matches
    }
    function activeLeaves() {
      return leaves.filter(function (l) {
        return l.el.style.display !== "none"
      })
    }

    // 순서 보존 이분할 트리 구축 (base weight로 절반씩 분할)
    function build(arr) {
      if (arr.length === 1) return { leaf: arr[0] }
      var tot = 0
      arr.forEach(function (l) {
        tot += l.base
      })
      var acc = 0,
        i = 0
      for (i = 0; i < arr.length - 1; i++) {
        acc += arr[i].base
        if (acc >= tot / 2) {
          i++
          break
        }
      }
      if (i < 1) i = 1
      if (i > arr.length - 1) i = arr.length - 1
      return { a: build(arr.slice(0, i)), b: build(arr.slice(i)), dir: null }
    }

    function wsum(n) {
      return n.leaf ? n.leaf.w : wsum(n.a) + wsum(n.b)
    }

    // 현재 weight로 사각형 배치. dir은 최초 1회(base 기준)만 결정해 구조를 고정.
    function place(n, x, y, w, h) {
      if (n.leaf) {
        var s = n.leaf.el.style
        s.left = x + "%"
        s.top = y + "%"
        s.width = w + "%"
        s.height = h + "%"
        return
      }
      if (n.dir === null) n.dir = w >= h ? "h" : "v"
      var wa = wsum(n.a),
        wb = wsum(n.b),
        t = wa + wb || 1
      if (n.dir === "h") {
        var ww = (w * wa) / t
        place(n.a, x, y, ww, h)
        place(n.b, x + ww, y, w - ww, h)
      } else {
        var hh = (h * wa) / t
        place(n.a, x, y, w, hh)
        place(n.b, x, y + hh, w, h - hh)
      }
    }

    var tree = null
    function clearInline() {
      tiles.forEach(function (el) {
        el.style.left = el.style.top = el.style.width = el.style.height = ""
      })
    }
    function rebuild() {
      if (!desktop()) {
        clearInline()
        tree = null
        return
      }
      var a = activeLeaves()
      a.forEach(function (l) {
        l.w = l.base
      })
      tree = a.length ? build(a) : null
      if (tree) place(tree, 0, 0, 100, 100)
    }
    function relayout(hoverLeaf) {
      if (!tree || !desktop()) return
      var a = activeLeaves()
      a.forEach(function (l) {
        l.w = l.base
      })
      if (hoverLeaf && !hoverLeaf.menu) {
        var others = 0
        a.forEach(function (l) {
          if (l !== hoverLeaf) others += l.base
        })
        hoverLeaf.w = (others * SHARE) / (1 - SHARE)
      }
      place(tree, 0, 0, 100, 100)
    }

    // 검색
    function apply() {
      var q = (input && input.value.trim().toLowerCase()) || ""
      var shown = 0
      leaves.forEach(function (l) {
        if (l.menu) return
        var hit = !q || (l.el.getAttribute("data-search") || "").indexOf(q) !== -1
        l.el.style.display = hit ? "" : "none"
        if (hit) shown++
      })
      if (none) none.hidden = shown !== 0
      rebuild()
    }
    if (input) input.addEventListener("input", apply)

    // hover-expand
    leaves.forEach(function (l) {
      if (l.menu) return
      l.el.addEventListener("mouseenter", function () {
        relayout(l)
      })
    })
    grid.addEventListener("mouseleave", function () {
      relayout(null)
    })

    var rt
    window.addEventListener("resize", function () {
      clearTimeout(rt)
      rt = setTimeout(rebuild, 150)
    })

    // 초기화: 위치 잡고 → 페이드인 → 전환 활성화
    rebuild()
    requestAnimationFrame(function () {
      c.classList.add("ready")
      requestAnimationFrame(function () {
        c.classList.add("animate")
      })
    })
  })()
</script>

<style>
  #packed {
    position: relative;
    width: 100%;
    height: 100svh;
  }

  /* 직사각형 그리드: 좌측 메뉴 컬럼 + 우측 여백 안쪽, 상하 여백 */
  .grid {
    position: absolute;
    left: 210px; /* 좌측 메뉴 컬럼 (아래는 빈 여백) */
    right: 56px; /* 우측 여백 */
    top: 14px;
    bottom: 14px;
  }

  .tile {
    position: absolute;
    overflow: hidden;
    border: 2px solid #fff;
    background: #f2f2f2;
    opacity: 0;
  }
  #packed.ready .tile {
    opacity: 1;
  }
  .tile {
    transition: opacity 0.45s ease;
  }
  #packed.animate .tile {
    transition:
      left 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
      top 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
      width 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
      height 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 0.45s ease;
  }

  /* 작품 셀 */
  .card {
    display: block;
    color: #fff;
  }
  .card .thumb,
  .card .ph {
    position: absolute;
    inset: 0;
  }
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card .ph {
    background: #ececec;
  }
  .card .cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 26px 12px 9px;
    font-size: 14px;
    line-height: 1.25;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.62), rgba(0, 0, 0, 0));
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .card:hover .cap {
    opacity: 1;
  }
  .card .cap .t {
    font-weight: 400;
  }
  .card .cap .y {
    font-weight: 300;
    opacity: 0.85;
  }

  /* 메뉴 = 좌상단 고정 오버레이 */
  .home-menu {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 3;
    width: 210px;
    padding: 15px 18px 18px;
    background: #fff;
    font-size: 18px;
    line-height: 1.5;
  }
  .home-menu .name {
    font-weight: 500;
    margin-bottom: 12px;
  }
  .home-menu a {
    display: block;
    color: #000;
  }
  .home-menu a:hover {
    border-bottom: 1px solid var(--hover);
    width: fit-content;
  }
  .home-menu a.current {
    border-bottom: 1px solid #000;
    width: fit-content;
  }
  .home-menu #search {
    display: block;
    width: 120px;
    margin-top: 14px;
    padding: 2px 0;
    border: 0;
    border-bottom: 1px solid #000;
    font: inherit;
    font-size: 15px;
    background: transparent;
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
  }
  .home-menu #search::placeholder {
    color: #000;
  }
  .home-menu #search:focus {
    border-bottom-color: var(--hover);
  }

  #noresult {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 15px;
    color: #888;
  }

  /* 홈에서는 전역 footer 숨김 (그리드가 화면을 채움) — 이 컴포넌트는 홈 전용 */
  :global(footer) {
    display: none;
  }

  /* 모바일: 패킹 해제하고 세로 블록으로 폴백 */
  @media (max-width: 700px) {
    #packed {
      height: auto;
      margin: 0;
      width: 100%;
    }
    .grid {
      position: static;
      left: auto;
      right: auto;
      top: auto;
      bottom: auto;
    }
    .tile {
      position: static !important;
      opacity: 1 !important;
      width: auto !important;
      height: auto !important;
      border: 0;
      margin: 24px 16px 0;
    }
    .card {
      position: relative;
      color: #000;
    }
    .card .thumb {
      position: relative;
      inset: auto;
    }
    .card img {
      height: auto;
    }
    .card .ph {
      position: relative;
      inset: auto;
      padding-bottom: 66%;
    }
    .card .cap {
      position: static;
      opacity: 1;
      padding: 4px 0 0;
      color: #000;
      background: none;
      font-size: 16px;
    }
    .home-menu {
      position: static;
      width: auto;
      padding: 12px 16px 4px;
    }
    :global(footer) {
      display: block;
    }
  }
</style>
