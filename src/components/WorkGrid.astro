---
import { getCollection } from "astro:content"

const { filter = "", current = "works" } = Astro.props

const WIDTH = { "1col": "w-1col", "2col": "w-2col", "3col": "w-3col" }

let works = await getCollection("works", ({ data }) => !data.draft)
if (filter) works = works.filter((w) => w.data.category === filter)
works.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))

const nav = [
  { label: "Works", href: "/works", key: "works" },
  { label: "Sound", href: "/sound", key: "sound" },
  { label: "Bio", href: "/cv", key: "bio" },
  { label: "Contact", href: "/contact", key: "contact" },
]
---

<div id="index">
  <!-- 메뉴 = 그리드 첫 칸 (레퍼런스 방식) -->
  <div class="cell menu">
    <div class="name"><a href="/">HWANYUN</a></div>
    {
      nav.map((n) => (
        <a href={n.href} class={current === n.key ? "current" : ""}>
          {n.label}
        </a>
      ))
    }
    <input id="search" type="search" placeholder="Search" autocomplete="off" />
  </div>

  {
    works.map((w) => (
      <a
        class={`cell ${WIDTH[w.data.size]} card`}
        href={`/works/${w.slug}`}
        data-search={`${w.data.title} ${w.data.year} ${w.data.medium}`.toLowerCase()}
      >
        <div class="thumb" style={w.data.thumb ? `--bg:url(${w.data.thumb})` : ""}>
          {w.data.thumb ? (
            <img src={w.data.thumb} alt={w.data.title} />
          ) : (
            <div class="ph" />
          )}
          <span class="scan" aria-hidden="true"></span>
        </div>
        <div class="cap">
          {w.data.title}
          {w.data.year ? ` (${w.data.year})` : ""}
        </div>
      </a>
    ))
  }
  <div id="noresult" hidden>No results.</div>
</div>

<script is:inline>
  ;(function () {
    var input = document.getElementById("search")
    if (!input) return
    var cards = Array.prototype.slice.call(document.querySelectorAll(".card"))
    var none = document.getElementById("noresult")
    function apply() {
      var q = input.value.trim().toLowerCase()
      var shown = 0
      cards.forEach(function (c) {
        var hit = !q || (c.getAttribute("data-search") || "").indexOf(q) !== -1
        c.style.display = hit ? "" : "none"
        if (hit) shown++
      })
      if (none) none.hidden = shown !== 0
    }
    input.addEventListener("input", apply)
  })()
</script>

<style>
  #index {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-auto-flow: row dense;
    gap: 16px 10px;
    padding: 10px;
    position: relative;
    z-index: 1;
  }
  .cell { min-width: 0; font-size: 0; }
  .cell.w-1col { grid-column: span 3; }
  .cell.w-2col { grid-column: span 4; }
  .cell.w-3col { grid-column: span 5; }

  .menu { grid-column: span 2; font-size: 18px; line-height: 1.5; }
  .menu .name { font-weight: 500; margin-bottom: 12px; }
  .menu a { display: block; }
  .menu a:hover { border-bottom: 1px solid var(--hover); width: fit-content; }
  .menu a.current { border-bottom: 1px solid #000; width: fit-content; }
  .menu #search {
    display: block;
    width: 120px;
    margin-top: 14px;
    padding: 2px 0;
    border: 0;
    border-bottom: 1px solid #000;
    font: inherit;
    font-size: 15px;
    background: transparent;
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
  }
  .menu #search::placeholder { color: #000; }
  .menu #search:focus { border-bottom-color: var(--hover); }

  #noresult { grid-column: 1 / -1; font-size: 15px; color: #888; }

  .card .thumb { position: relative; line-height: 0; overflow: hidden; }
  .card img,
  .card .ph { width: 100%; display: block; }
  .card .ph { background: #ececec; padding-bottom: 75%; }

  /* 기본은 통일된 흑백 → 마우스 오버 시 원래 컬러로 (데이터가 디코딩되듯) */
  .card img { filter: grayscale(1); transition: filter 0.35s ease; }
  .card:hover img { filter: grayscale(0); }

  /* RGB 채널 분리 레이어 — hover 진입 시 잠깐 어긋났다가 사라져 깨끗한 컬러로 정착 */
  .card .thumb::before,
  .card .thumb::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--bg) center / cover no-repeat;
    mix-blend-mode: screen;
    opacity: 0;
    pointer-events: none;
  }
  .card .thumb::before { filter: sepia(1) saturate(6) hue-rotate(-55deg); }  /* red-ish 채널 */
  .card .thumb::after  { filter: sepia(1) saturate(6) hue-rotate(150deg); }  /* cyan-ish 채널 */
  .card:hover .thumb::before { animation: decodeR 0.5s steps(3, end) 1 both; }
  .card:hover .thumb::after  { animation: decodeB 0.5s steps(3, end) 1 both; }

  /* 스캔라인 — hover 동안 은은히 유지되어 신호/데이터 질감 */
  .card .scan {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(to bottom, rgba(0, 0, 0, 0.16) 0 1px, transparent 1px 3px);
    mix-blend-mode: multiply;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .card:hover .scan { opacity: 1; }

  /* 상단 → 하단으로 한 번 훑고 지나가는 애시드 라임 스캔 라인 (데이터 읽어들이는 느낌) */
  .card .scan::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: -16%;
    height: 16%;
    background: linear-gradient(to bottom, rgba(198, 255, 0, 0), rgba(198, 255, 0, 0.45), rgba(198, 255, 0, 0));
    opacity: 0;
    pointer-events: none;
  }
  .card:hover .scan::after { animation: sweep 0.7s ease-out 1 both; }

  @keyframes decodeR {
    0%   { opacity: 0.6;  transform: translateX(-6px); clip-path: inset(0 0 66% 0); }
    33%  { opacity: 0.5;  transform: translateX(4px);  clip-path: inset(40% 0 30% 0); }
    66%  { opacity: 0.35; transform: translateX(-2px); clip-path: inset(72% 0 0 0); }
    100% { opacity: 0;    transform: translateX(0);    clip-path: inset(0 0 0 0); }
  }
  @keyframes decodeB {
    0%   { opacity: 0.6;  transform: translateX(6px);  clip-path: inset(60% 0 12% 0); }
    33%  { opacity: 0.5;  transform: translateX(-4px); clip-path: inset(12% 0 55% 0); }
    66%  { opacity: 0.35; transform: translateX(2px);  clip-path: inset(0 0 74% 0); }
    100% { opacity: 0;    transform: translateX(0);    clip-path: inset(0 0 0 0); }
  }
  @keyframes sweep {
    0%   { opacity: 0.9; top: -16%; }
    100% { opacity: 0;   top: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .card:hover .thumb::before,
    .card:hover .thumb::after,
    .card:hover .scan::after { animation: none; }
  }

  .card .cap { font-size: 16px; line-height: 1.3; margin: 4px 0 0; }
  .card:hover .cap { color: var(--hover); }

  @media (max-width: 700px) {
    #index { display: block; padding: 0; }
    .cell,
    .cell.w-1col,
    .cell.w-2col,
    .cell.w-3col {
      float: none;
      width: auto;
      margin: 28px 16px 0;
    }
  }
</style>
