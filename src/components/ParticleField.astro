---
// 홈 배경 — 마우스에 반응하는 제너레이티브 파티클 네트워크 (흑백, 은은함)
---

<canvas id="pfield" aria-hidden="true"></canvas>

<script is:inline>
  ;(function () {
    var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches
    var canvas = document.getElementById("pfield")
    if (!canvas) return
    var ctx = canvas.getContext("2d")
    var dpr = Math.min(window.devicePixelRatio || 1, 2)
    var W = 0, H = 0
    var particles = []
    var mouse = { x: -9999, y: -9999, active: false }

    // 화면 크기에 비례해 입자 수 결정 (성능 캡)
    function count() {
      return Math.min(120, Math.round((window.innerWidth * window.innerHeight) / 16000))
    }

    function resize() {
      W = window.innerWidth
      H = window.innerHeight
      canvas.width = W * dpr
      canvas.height = H * dpr
      canvas.style.width = W + "px"
      canvas.style.height = H + "px"
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
    }

    function seed() {
      particles = []
      var n = count()
      for (var i = 0; i < n; i++) {
        particles.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.25,
          vy: (Math.random() - 0.5) * 0.25,
          r: Math.random() * 1.4 + 0.6,
        })
      }
    }

    var LINK = 120     // 입자끼리 연결되는 거리
    var MOUSE_R = 170  // 마우스 영향 반경

    function step() {
      ctx.clearRect(0, 0, W, H)
      var p, q, i, j, dx, dy, d

      for (i = 0; i < particles.length; i++) {
        p = particles[i]
        // 기본 드리프트
        p.x += p.vx
        p.y += p.vy
        // 마우스 인력 (부드럽게 따라옴)
        if (mouse.active) {
          dx = mouse.x - p.x
          dy = mouse.y - p.y
          d = Math.sqrt(dx * dx + dy * dy)
          if (d < MOUSE_R && d > 0.1) {
            var f = (1 - d / MOUSE_R) * 0.6
            p.x += (dx / d) * f
            p.y += (dy / d) * f
          }
        }
        // 화면 밖으로 나가면 반대편으로 (감싸기)
        if (p.x < -20) p.x = W + 20
        if (p.x > W + 20) p.x = -20
        if (p.y < -20) p.y = H + 20
        if (p.y > H + 20) p.y = -20
      }

      // 입자 간 연결선
      for (i = 0; i < particles.length; i++) {
        p = particles[i]
        for (j = i + 1; j < particles.length; j++) {
          q = particles[j]
          dx = p.x - q.x
          dy = p.y - q.y
          d = Math.sqrt(dx * dx + dy * dy)
          if (d < LINK) {
            ctx.strokeStyle = "rgba(0,0,0," + (0.06 * (1 - d / LINK)).toFixed(3) + ")"
            ctx.beginPath()
            ctx.moveTo(p.x, p.y)
            ctx.lineTo(q.x, q.y)
            ctx.stroke()
          }
        }
      }

      // 마우스 → 가까운 입자 연결 (강조)
      if (mouse.active) {
        for (i = 0; i < particles.length; i++) {
          p = particles[i]
          dx = p.x - mouse.x
          dy = p.y - mouse.y
          d = Math.sqrt(dx * dx + dy * dy)
          if (d < MOUSE_R) {
            ctx.strokeStyle = "rgba(0,0,255," + (0.18 * (1 - d / MOUSE_R)).toFixed(3) + ")"
            ctx.beginPath()
            ctx.moveTo(p.x, p.y)
            ctx.lineTo(mouse.x, mouse.y)
            ctx.stroke()
          }
        }
      }

      // 입자 점
      ctx.fillStyle = "rgba(0,0,0,0.35)"
      for (i = 0; i < particles.length; i++) {
        p = particles[i]
        ctx.beginPath()
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2)
        ctx.fill()
      }

      raf = requestAnimationFrame(step)
    }

    var raf = null
    window.addEventListener("mousemove", function (e) {
      mouse.x = e.clientX
      mouse.y = e.clientY
      mouse.active = true
    })
    window.addEventListener("mouseleave", function () { mouse.active = false })
    window.addEventListener("resize", function () { resize(); seed() })

    resize()
    seed()
    if (reduce) {
      step() // 한 프레임만 그리고 정지
      cancelAnimationFrame(raf)
    } else {
      step()
    }
  })()
</script>

<style>
  #pfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none; /* 클릭·스크롤 방해 안 함 */
  }
</style>
