---
import { getCollection } from "astro:content"
import Base from "../../layouts/Base.astro"

const works = await getCollection("works", ({ data }) => !data.draft)
works.sort((a, b) => {
  const sortYear = (year: string) => Math.max(...(year.match(/\d{4}/g) ?? ["0"]).map(Number))
  const byYear = sortYear(b.data.year) - sortYear(a.data.year)
  return byYear || (a.data.order ?? 0) - (b.data.order ?? 0)
})
---

<Base title="Works — HWANYUN" current="works">
  <main class="works-archive">
    <header class="archive-intro">
      <p class="eyebrow">WORK ARCHIVE</p>
      <h1>Works</h1>
      <div class="intro-copy">
        <p lang="en">
          An archive of installations, moving-image works, and interactive systems.
          Each project examines how sound, material, technology, and site are brought
          into relation through embodied experience.
        </p>
        <p lang="ko">
          설치, 영상, 그리고 인터랙티브 시스템으로 구성된 작업 아카이브. 각 프로젝트는
          신체적 경험을 매개로 소리, 물질, 기술, 장소가 맺는 관계를 탐구한다.
        </p>
      </div>
    </header>

    <section class="archive-list" aria-label="Works by year">
      <div class="archive-head" aria-hidden="true">
        <span>WORKS</span>
        <span>YEAR</span>
      </div>
      <ol>
        {
          works.map((work) => (
            <li>
              <a href={`/works/${work.slug}`}>
                <time>{work.data.year}</time>
                <span>{work.data.title}</span>
              </a>
            </li>
          ))
        }
      </ol>
    </section>
  </main>
</Base>

<style>
  .works-archive {
    margin: 10px 40px 100px 170px;
    max-width: 720px;
  }

  .archive-intro { max-width: 650px; margin: 0 0 84px; }
  .eyebrow {
    margin: 0;
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #888;
  }
  h1 {
    margin: 8px 0 16px;
    font-size: 38px;
    font-weight: 300;
    line-height: 1.15;
  }
  .intro-copy {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 3%;
  }
  .intro-copy p {
    margin: 0;
    padding-top: 12px;
    border-top: 1px solid #000;
    font-size: 16px;
    line-height: 1.8;
    color: #555;
  }
  .intro-copy p[lang="ko"] { line-height: 1.85; }

  ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .archive-head,
  li a {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 66px;
    gap: 16px;
  }

  .archive-head {
    border-top: 1px solid #111;
    border-bottom: 1px solid #111;
    padding: 5px 0 4px;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.025em;
  }

  .archive-head span:last-child { text-align: right; }

  li { border-bottom: 1px solid #8b8b8b; }

  li a {
    align-items: baseline;
    padding: 5px 0 6px;
  }

  time {
    grid-column: 2;
    grid-row: 1;
    text-align: right;
    font-size: 15px;
    font-weight: 300;
    letter-spacing: 0.025em;
  }

  li span {
    grid-column: 1;
    grid-row: 1;
    font-size: 18px;
    font-weight: 300;
    line-height: 1.16;
    letter-spacing: 0.012em;
  }

  li a:hover { color: var(--hover); }

  @media (max-width: 700px) {
    .works-archive { margin: 24px 16px 80px; }
    .archive-intro { margin-bottom: 54px; }
    h1 { font-size: 32px; }
    .intro-copy { grid-template-columns: 1fr; gap: 18px; }
    .archive-head,
    li a { grid-template-columns: minmax(0, 1fr) 48px; gap: 8px; }
    .archive-head { font-size: 15px; }
    time { font-size: 13px; }
    li span { font-size: 16px; }
  }
</style>
