    /* 사진 층 — 기본(모바일 폴백): 세로 스택, 자르지 않음 */
    .media-stills { clear: both; margin: 0; }
    .media-stills .block { margin: 0 0 24px; }
    .media-stills .block:last-child { margin-bottom: 0; }
    .media-stills .block img { display: block; width: 100%; height: auto; }
    .media-stills figcaption { margin-top: 8px; font-size: 13px; color: #666; }

    /* 데스크톱: 홈과 같은 hover-expand 패킹 그리드 — 콘텐츠 폭 안 직사각형.
       hover로 커져도 object-fit:contain + 중립 배경이라 이미지가 잘리지 않고 전체가 보임. */
    @media (min-width: 701px) {
      .media-stills {
        position: relative;
        margin-top: 0;
        width: 100%;
        height: min(70vh, 640px);
      }
      .media-stills .block {
        position: absolute;
        margin: 0;
        overflow: hidden;
        border: 2px solid #fff;
        background: #f2f2f2;
        opacity: 0;
      }
      .media-stills.ready .block { opacity: 1; transition: opacity 0.4s ease; }
      .media-stills.animate .block {
        transition:
          left 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
          top 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
          width 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
          height 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
          opacity 0.4s ease;
      }
      .media-stills .block img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover; /* 항상 꽉 채움 — hover 시 타일이 사진 비율에 맞게 길쭉해져서 잘림 없이 전체가 보임(JS) */
      }
      .media-stills figcaption {
        position: absolute;
