---
import { getCollection } from "astro:content"
import Base from "../../layouts/Base.astro"

export async function getStaticPaths() {
  const works = await getCollection("works", ({ data }) => !data.draft)
  return works.map((w) => ({ params: { slug: w.slug }, props: { work: w } }))
}

const { work } = Astro.props
const { data } = work
const { Content } = await work.render()
const yr = data.year ? ` (${data.year})` : ""
const allWorks = await getCollection("works", ({ data }) => !data.draft)
const allSounds = await getCollection("sounds", ({ data }) => !data.draft)
const seriesWorks = data.series
  ? allWorks
      .filter((item) => item.data.series?.id === data.series?.id)
      .sort((a, b) => a.data.order - b.data.order)
  : []
const relatedSounds = allSounds
  .filter((sound) => sound.data.works.includes(work.slug))
  .sort((a, b) => a.data.order - b.data.order)
const useImmersiveMedia = work.slug !== "fedora-exile"

// 영상 URL을 임베드 가능한 형태로 정규화 (YouTube/Vimeo는 일반 링크를 붙여도 됨)
function embedURL(url: string): { kind: "iframe" | "file"; src: string } {
  const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]+)/)
  if (yt) return { kind: "iframe", src: `https://www.youtube.com/embed/${yt[1]}` }
  const vm = url.match(/vimeo\.com\/(?:video\/)?(\d+)(?:[?&]h=([\w]+))?/)
  if (vm) {
    const hash = vm[2] ? `?h=${vm[2]}` : ""
    return { kind: "iframe", src: `https://player.vimeo.com/video/${vm[1]}${hash}` }
  }
  if (/\.(mp4|webm|mov)(\?.*)?$/i.test(url)) return { kind: "file", src: url }
  return { kind: "iframe", src: url } // 이미 embed URL이면 그대로
}

const ratioValue: Record<string, string> = {
  "16:9": "16 / 9",
  "4:3": "4 / 3",
  "1:1": "1 / 1",
  "21:9": "21 / 9",
  "9:16": "9 / 16",
}
// 종횡비 숫자값 — justified 행에서 flex-grow(폭 배분)에 사용
const ratioNum: Record<string, number> = {
  "16:9": 16 / 9,
  "4:3": 4 / 3,
  "1:1": 1,
  "21:9": 21 / 9,
  "9:16": 9 / 16,
}

const media = data.media ?? []
const galleryMedia = data.mediaFirst && !useImmersiveMedia ? media.slice(1) : media
const hasText = data.textEn || data.textKr

// 미디어 층위 분리: 움직이는 이미지(영상)를 앞·크게, 스틸(사진)은 아래 갤러리로
const videoMedia = galleryMedia.filter((m) => m.type === "video")
const stillMedia = galleryMedia.filter((m) => m.type !== "video")
// 세로 영상(9:16)은 나란히 묶고, 가로 영상은 풀와이드로
const isPortrait = (m: (typeof media)[number]) => m.ratio === "9:16"

// 매체 표기: ";" 기준으로 종류 / 재료 분리 → 종류 한 줄, 재료 아래 줄
const mediumParts = (data.medium || "")
  .split(";")
  .map((s) => s.trim())
  .filter(Boolean)

const defaultLayout = (m: (typeof media)[number], index: number) => {
  // 공통 편집 규칙: 첫 장은 대표 이미지, full은 주요 기록,
  // third·세로 영상은 보조/디테일로 읽히게 한다.
  if (m.layout) return m.layout
  if (index === 0) return "hero"
  if (m.type === "video" && m.ratio === "9:16") return "portrait"
  if (m.width === "full") return "wide"
  if (m.width === "third") return "detail"
  return "standard"
}

// 설명 텍스트: 빈 줄은 문단 구분, 문단 안 줄바꿈은 공백으로 이어 자연스럽게 흐르게
function toParagraphs(text: string): string {
  return (text || "")
    .trim()
    .split(/\n\s*\n/)
    .map((p) => `<p>${p.replace(/\n/g, " ").trim()}</p>`)
    .join("")
}
---

<Base title={`HWANYUN — ${data.title}`}>
  <div id="entry" data-media-prototype={useImmersiveMedia ? "true" : undefined}>
    <div class="entry_title">{data.title}{yr}</div>

    {
      mediumParts.length > 0 && (
        <p class="meta">
          <span class="medium-type">{mediumParts[0]}</span>
          {mediumParts.length > 1 && (
            <span class="medium-materials">{mediumParts.slice(1).join("; ")}</span>
          )}
        </p>
      )
    }

    {
      data.series && seriesWorks.length > 1 && (
        <nav class="series-link" aria-label={`${data.series.label} series`}>
          <span>Part of the series</span>
          <div class="series-members">
            {seriesWorks.map((item) =>
              item.slug === work.slug ? (
                <span class="series-current" aria-current="page">{item.data.title}</span>
              ) : (
                <a href={`/works/${item.slug}/`}>{item.data.title}</a>
              )
            )}
          </div>
        </nav>
      )
    }

    {
      data.mediaFirst && !useImmersiveMedia && media[0] && (
        <div class="media media--lead">
          {media[0].type === "video" ? (
            <figure class={`block is-video ${defaultLayout(media[0], 0)} ${media[0].align ? `align-${media[0].align}` : ""}`}>
              <div class="video" style={`aspect-ratio:${ratioValue[media[0].ratio] || "16 / 9"}`}>
                {embedURL(media[0].src).kind === "iframe" ? (
                  <iframe src={embedURL(media[0].src).src} allowfullscreen frameborder="0" loading="lazy" />
                ) : (
                  <video src={embedURL(media[0].src).src} controls playsinline />
                )}
              </div>
              {media[0].caption && <figcaption>{media[0].caption}</figcaption>}
              {(media[0].noteEn || media[0].noteKr) && (
                <div class="media-note">
                  {media[0].noteLabel && <div class="media-note-label">{media[0].noteLabel}</div>}
                  <div class="media-note-cols">
                    <p>{media[0].noteEn}</p>
                    <p>{media[0].noteKr}</p>
                  </div>
                </div>
              )}
            </figure>
          ) : (
            <figure class={`block ${defaultLayout(media[0], 0)} ${media[0].align ? `align-${media[0].align}` : ""}`}>
              <img src={media[0].src} alt={media[0].caption || data.title} loading="lazy" />
              {media[0].caption && <figcaption>{media[0].caption}</figcaption>}
            </figure>
          )}
        </div>
      )
    }

    <!-- EN / KR 2단 텍스트 — 글자가 없어도 항상 2단 (레퍼런스 구조) -->
    <div class="textcols">
      <div class="col" set:html={toParagraphs(data.textEn)} />
      <div class="col kr" set:html={toParagraphs(data.textKr)} />
    </div>

    <!-- 마크다운 본문(선택) -->
    <div class="desc"><Content /></div>

    {
      data.processNote && (data.processNote.textEn || data.processNote.textKr) && (
        <aside class="process-note" aria-label={data.processNote.label}>
          <div class="process-note-cols">
            {data.processNote.textEn && <p>{data.processNote.textEn}</p>}
            {data.processNote.textKr && <p lang="ko">{data.processNote.textKr}</p>}
          </div>
        </aside>
      )
    }

    <!-- 영상 층: 움직이는 이미지가 작품의 본체 → 앞·크게 -->
    {
      videoMedia.length > 0 && (
        <div class={`layer-label ${useImmersiveMedia ? "media-reveal" : ""}`}>Video</div>
      )
    }
    {
      videoMedia.length > 0 && (
        <div class={`media-videos ${useImmersiveMedia ? "media-reveal" : ""}`}>
          {videoMedia.map((m) => (
            <figure
              class="block is-video"
              style={`flex-grow:${ratioNum[m.ratio] || 16 / 9};flex-basis:0`}
            >
              <div class={`video ${useImmersiveMedia ? "video-preview" : ""}`} style={`aspect-ratio:${ratioValue[m.ratio] || "16 / 9"}`}>
                {embedURL(m.src).kind === "iframe" ? (
                  <iframe src={embedURL(m.src).src} allowfullscreen frameborder="0" loading="lazy" tabindex={useImmersiveMedia ? "-1" : undefined} />
                ) : (
                  <video src={embedURL(m.src).src} controls={!useImmersiveMedia} preload={useImmersiveMedia ? "metadata" : undefined} muted={useImmersiveMedia} playsinline />
                )}
                {useImmersiveMedia && <button class="video-play" type="button" aria-label={`Play ${m.caption || data.title}`}><span aria-hidden="true"></span></button>}
              </div>
              {m.caption && <figcaption>{m.caption}</figcaption>}
              {(m.noteEn || m.noteKr) && (
                <div class="media-note">
                  {m.noteLabel && <div class="media-note-label">{m.noteLabel}</div>}
                  <div class="media-note-cols">
                    <p>{m.noteEn}</p>
                    <p>{m.noteKr}</p>
                  </div>
                </div>
              )}
            </figure>
          ))}
        </div>
      )
    }

    <!-- 사진 층: 스틸 기록을 건축 모듈 그리드로 -->
    {
      stillMedia.length > 0 && (
        <div class={`layer-label ${useImmersiveMedia ? "media-reveal" : ""}`}>Images</div>
      )
    }
    {
      stillMedia.length > 0 && (
        <div class={`media-stills ${useImmersiveMedia ? "media-reveal" : ""}`}>
          {stillMedia.map((m) => (
            <figure class="block" data-span={m.span ? String(m.span) : undefined}>
              <img src={m.src} alt={m.caption || data.title} loading="lazy" />
              {m.caption && <figcaption>{m.caption}</figcaption>}
            </figure>
          ))}
        </div>
      )
    }

    {
      media.length === 0 && (
        <div class="media-stills">
          <figure class="block"><div class="ph" style="padding-bottom:120%" /></figure>
        </div>
      )
    }

    <div class="post-gallery-divider" aria-hidden="true"></div>

    {
      relatedSounds.length > 0 && (
        <section class="related-sounds" aria-labelledby="related-sounds-title">
          <div id="related-sounds-title" class="related-sounds-label">Related sound recordings</div>
          <div class="related-sounds-list">
            {relatedSounds.map((sound) => (
              <a href={`/sound/#sound-${sound.slug}`}>
                <span>{sound.data.title}</span>
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      data.exhibition && (
        <div class="exhibition-credit">
          {data.exhibition.label && <div class="exhibition-label">{data.exhibition.label}</div>}
          <div class="exhibition-title">
            {data.exhibition.titleEn && <span>{data.exhibition.titleEn}</span>}
            {data.exhibition.titleKr && <span lang="ko">{data.exhibition.titleKr}</span>}
            {(data.exhibition.venue || data.exhibition.year) && (
              <span class="exhibition-meta">{[data.exhibition.venue, data.exhibition.year].filter(Boolean).join(", ")}</span>
            )}
          </div>
        </div>
      )
    }

    {
      data.externalLinks && data.externalLinks.length > 0 && (
        <section class="external-links" aria-label="Further reading">
          <div class="external-links-label">Further Reading</div>
          <div class="external-links-list">
            {data.externalLinks.map((link) => (
              <a href={link.url} target="_blank" rel="noopener">
                <span>{link.title}</span>
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      data.sponsors && data.sponsors.length > 0 && (
        <div class="sponsors">
          <div class="sponsors-label">Exhibition Sponsors</div>
          <div class="sponsors-row">
            {data.sponsors.map((s) =>
              s.url ? (
                <a href={s.url} target="_blank" rel="noopener" class="sponsor">
                  {s.logo ? <img src={s.logo} alt={s.name} loading="lazy" /> : <span class="sponsor-name">{s.name}</span>}
                </a>
              ) : (
                <span class="sponsor">
                  {s.logo ? <img src={s.logo} alt={s.name} loading="lazy" /> : <span class="sponsor-name">{s.name}</span>}
                </span>
              )
            )}
          </div>
        </div>
      )
    }
  </div>

  <!-- 포커스 모드(밝은 라이트박스): 미디어 클릭 시 중앙에 크게 -->
  <div id="focus" class="focus" hidden>
    <button class="focus-close" aria-label="Close">×</button>
    <div class="focus-stage"></div>
    <div class="focus-cap"></div>
  </div>

  <script is:inline>
    ;(function () {
      var overlay = document.getElementById("focus")
      if (!overlay) return
      var stage = overlay.querySelector(".focus-stage")
      var cap = overlay.querySelector(".focus-cap")
      var closeBtn = overlay.querySelector(".focus-close")
      var figures = Array.prototype.slice.call(document.querySelectorAll("#entry .block"))

      function openFig(fig) {
        var media = fig.querySelector("img, .video")
        if (!media) return
        var clone = media.cloneNode(true)
        var previewButton = clone.querySelector && clone.querySelector(".video-play")
        if (previewButton) previewButton.remove()
        // 파일 영상은 컨트롤+자동재생, 임베드는 autoplay 파라미터 부여
        var vid = clone.tagName === "VIDEO" ? clone : clone.querySelector && clone.querySelector("video")
        if (vid) {
          vid.setAttribute("controls", "")
          vid.setAttribute("autoplay", "")
        }
        var ifr = clone.querySelector && clone.querySelector("iframe")
        if (ifr) {
          var s = ifr.getAttribute("src") || ""
          ifr.setAttribute("src", s + (s.indexOf("?") > -1 ? "&" : "?") + "autoplay=1")
        }
        stage.innerHTML = ""
        stage.appendChild(clone)
        var fc = fig.querySelector("figcaption")
        cap.textContent = fc ? fc.textContent : ""
        cap.style.display = fc ? "" : "none"
        overlay.hidden = false
        overlay.classList.toggle("video-focus", fig.classList.contains("is-video"))
        requestAnimationFrame(function () {
          overlay.classList.add("open")
        })
        document.body.style.overflow = "hidden"
      }
      function close() {
        overlay.classList.remove("open")
        overlay.classList.remove("video-focus")
        document.body.style.overflow = ""
        setTimeout(function () {
          overlay.hidden = true
          stage.innerHTML = "" // 영상 정지
        }, 280)
      }

      figures.forEach(function (fig) {
        var videoPlay = fig.querySelector(".video-play")
        if (videoPlay) {
          videoPlay.addEventListener("click", function (e) {
            e.stopPropagation()
            openFig(fig)
          })
          return
        }
        var btn = document.createElement("button")
        btn.className = "focus-open"
        btn.setAttribute("aria-label", "Enlarge")
        btn.innerHTML = "&#10530;" // ⤢
        btn.addEventListener("click", function (e) {
          e.stopPropagation()
          openFig(fig)
        })
        fig.appendChild(btn)
        if (!fig.classList.contains("is-video")) {
          var img = fig.querySelector("img")
          if (img) {
            img.style.cursor = "zoom-in"
            img.addEventListener("click", function () {
              openFig(fig)
            })
          }
        }
      })
      closeBtn.addEventListener("click", close)
      overlay.addEventListener("click", function (e) {
        if (e.target === overlay || e.target === stage) close()
      })
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && !overlay.hidden) close()
      })

      document.querySelectorAll(".video-preview video").forEach(function (video) {
        video.addEventListener("loadedmetadata", function () {
          if (video.duration > 0.12) video.currentTime = 0.12
        }, { once: true })
      })
    })()
  </script>

  <script is:inline>
    ;(function () {
      var targets = document.querySelectorAll("#entry[data-media-prototype='true'] .media-reveal")
      if (!targets.length) return
      if (!('IntersectionObserver' in window)) {
        targets.forEach(function (target) { target.classList.add("is-visible") })
        return
      }
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return
          entry.target.classList.add("is-visible")
          observer.unobserve(entry.target)
        })
      }, { threshold: 0.12, rootMargin: "0px 0px -7%" })
      targets.forEach(function (target) { observer.observe(target) })
    })()
  </script>

  <script is:inline>
    /* 사진 갤러리: 각 사진이 자기 비율 그대로의 직사각형 타일 → 행으로 폭을 꽉 채움(justified).
       resting에서 잘림 0. hover 시 그 타일이 크게 떠오름(전체 그대로). 데스크톱 전용. */
    ;(function () {
      var grid = document.querySelector(".media-stills")
      if (!grid) return
      var figs = Array.prototype.slice.call(grid.querySelectorAll(".block"))
      if (!figs.length) return
      var GAP = 14
      var TARGET = 320 // 목표 행 높이(px) — 사진 비율에 따라 폭이 정해짐
      function desktop() {
        return window.matchMedia("(min-width: 701px)").matches
      }
      function arOf(fig) {
        var img = fig.querySelector("img")
        if (img && img.naturalWidth && img.naturalHeight) return img.naturalWidth / img.naturalHeight
        return 1
      }
      function clearInline() {
        figs.forEach(function (f) {
          f.style.left = f.style.top = f.style.width = f.style.height = ""
        })
        grid.style.height = ""
      }
      function layout() {
        if (!desktop()) {
          clearInline()
          return
        }
        var W = grid.clientWidth
        var y = 0
        var row = []
        var i = 0
        function flushRow(stretch) {
          if (!row.length) return
          // 행 안 타일들의 종횡비 합 → 목표 높이에서 총 폭 계산, W에 맞게 높이 보정
          var arSum = 0
          row.forEach(function (r) {
            arSum += r.ar
          })
          var gaps = GAP * (row.length - 1)
          var h = stretch ? (W - gaps) / arSum : TARGET
          if (!stretch && TARGET * arSum + gaps > W) h = (W - gaps) / arSum // 마지막 행도 넘치면 맞춤
          var x = 0
          row.forEach(function (r) {
            var w = h * r.ar
            r.fig.style.left = x + "px"
            r.fig.style.top = y + "px"
            r.fig.style.width = w + "px"
            r.fig.style.height = h + "px"
            x += w + GAP
          })
          y += h + GAP
          row = []
        }
        for (i = 0; i < figs.length; i++) {
          var ar = arOf(figs[i])
          row.push({ fig: figs[i], ar: ar })
          // 현재 행이 목표 높이에서 폭을 채우면 justify하고 새 행
          var arSum = 0
          row.forEach(function (r) {
            arSum += r.ar
          })
          var gaps = GAP * (row.length - 1)
          if (TARGET * arSum + gaps >= W) flushRow(true)
        }
        flushRow(false) // 마지막 행
        grid.style.height = Math.max(0, y - GAP) + "px"
      }
      // 이미지 로드/리사이즈마다 재계산
      figs.forEach(function (fig) {
        var img = fig.querySelector("img")
        if (img && !img.complete) {
          img.addEventListener("load", layout)
          img.addEventListener("error", layout)
        }
      })
      var rt
      window.addEventListener("resize", function () {
        clearTimeout(rt)
        rt = setTimeout(layout, 150)
      })
      layout()
      requestAnimationFrame(function () {
        grid.classList.add("ready")
      })
    })()
  </script>

  <style>
    /* 레퍼런스: 메뉴 170px 옆, 본문 최대 1100px */
    #entry {
      width: calc(100% - 170px);
      max-width: 1100px;
      float: left;
      margin: 10px 0 0 0;
      position: relative;
    }
    .entry_title {
      font-size: 34px;
      font-weight: 300;
      line-height: 1.25;
      margin-bottom: 22px;
    }
    .meta { font-size: 18px; font-weight: 400; line-height: 1.6; color: #555; margin: 0 0 34px; }
    .meta .medium-type { display: block; color: #111; }
    .meta .medium-materials { display: block; margin-top: 8px; font-size: 16px; color: #777; }
    .series-link {
      display: inline-flex;
      flex-direction: column;
      gap: 2px;
      margin: -14px 0 30px;
      font-size: 14px;
      line-height: 1.4;
      color: #333;
    }
    .series-link span {
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #999;
    }
    .series-members { display: flex; flex-wrap: wrap; gap: 0 10px; }
    .series-members a,
    .series-current { color: #333; }
    .series-members a + a::before,
    .series-members a + .series-current::before,
    .series-current + a::before { content: "·"; margin-right: 10px; color: #aaa; }
    .series-members a:hover { color: var(--hover); }
    .series-link:hover > span { color: var(--hover); }

    /* EN/KR 2단 — 본문 가독성만 개선(두께 400 / 16px / 넓은 줄간격) */
    .textcols::after { content: ""; display: block; clear: both; }
    .textcols .col {
      width: 46.5%;
      float: left;
      margin: 0 3% 30px 0;
      padding: 12px 0 0 0;
      border-top: 1px solid #000;
      font-size: 16px;
      font-weight: 400;
      line-height: 1.8;
      color: #555;
    }
    .textcols .col.kr { line-height: 1.85; }
    .textcols .col p { margin: 0 0 1em; }
    .textcols .col p:last-child { margin-bottom: 0; }

    .desc { font-size: 16px; font-weight: 400; line-height: 1.8; max-width: 640px; margin: 0 0 30px; }
    .desc :global(p) { margin: 0 0 1em; }
    .process-note {
      clear: both;
      margin: -4px 0 42px;
      color: #999;
    }
    .process-note-cols { display: grid; grid-template-columns: 46.5% 46.5%; column-gap: 3%; }
    .process-note p { margin: 0; font-size: 14px; line-height: 1.75; }

    /* 미디어 — 홈 그리드처럼 220/380/540 크기가 여백 있게 흐름 */
    .media {
      clear: both;
