---
import { getCollection } from "astro:content"
import Base from "../../layouts/Base.astro"

export async function getStaticPaths() {
  const works = await getCollection("works", ({ data }) => !data.draft)
  return works.map((w) => ({ params: { slug: w.slug }, props: { work: w } }))
}

const { work } = Astro.props
const { data } = work
const { Content } = await work.render()
const yr = data.year ? ` (${data.year})` : ""

// 영상 URL을 임베드 가능한 형태로 정규화 (YouTube/Vimeo는 일반 링크를 붙여도 됨)
function embedURL(url: string): { kind: "iframe" | "file"; src: string } {
  const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]+)/)
  if (yt) return { kind: "iframe", src: `https://www.youtube.com/embed/${yt[1]}` }
  const vm = url.match(/vimeo\.com\/(?:video\/)?(\d+)(?:[?&]h=([\w]+))?/)
  if (vm) {
    const hash = vm[2] ? `?h=${vm[2]}` : ""
    return { kind: "iframe", src: `https://player.vimeo.com/video/${vm[1]}${hash}` }
  }
  if (/\.(mp4|webm|mov)(\?.*)?$/i.test(url)) return { kind: "file", src: url }
  return { kind: "iframe", src: url } // 이미 embed URL이면 그대로
}

const ratioValue: Record<string, string> = {
  "16:9": "16 / 9",
  "4:3": "4 / 3",
  "1:1": "1 / 1",
  "21:9": "21 / 9",
  "9:16": "9 / 16",
}

const media = data.media ?? []
const hasText = data.textEn || data.textKr

// 매체 표기: ";" 기준으로 종류 / 재료 분리 → 종류 한 줄, 재료 아래 줄
const mediumParts = (data.medium || "")
  .split(";")
  .map((s) => s.trim())
  .filter(Boolean)

const defaultLayout = (m: (typeof media)[number], index: number) => {
  // 공통 편집 규칙: 첫 장은 대표 이미지, full은 주요 기록,
  // third·세로 영상은 보조/디테일로 읽히게 한다.
  if (m.layout) return m.layout
  if (index === 0) return "hero"
  if (m.type === "video" && m.ratio === "9:16") return "portrait"
  if (m.width === "full") return "wide"
  if (m.width === "third") return "detail"
  return "standard"
}

// 설명 텍스트: 빈 줄은 문단 구분, 문단 안 줄바꿈은 공백으로 이어 자연스럽게 흐르게
function toParagraphs(text: string): string {
  return (text || "")
    .trim()
    .split(/\n\s*\n/)
    .map((p) => `<p>${p.replace(/\n/g, " ").trim()}</p>`)
    .join("")
}
---

<Base title={`HWANYUN — ${data.title}`}>
  <div id="entry">
    <div class="entry_title">{data.title}{yr}</div>

    {
      mediumParts.length > 0 && (
        <p class="meta">
          <span class="medium-type">{mediumParts[0]}</span>
          {mediumParts.length > 1 && (
            <span class="medium-materials">{mediumParts.slice(1).join("; ")}</span>
          )}
        </p>
      )
    }

    {
      data.series && (
        <a class="series-link" href={data.series.href}>
          <span>Part of the series</span>
          {data.series.label}
        </a>
      )
    }

    <!-- EN / KR 2단 텍스트 — 글자가 없어도 항상 2단 (레퍼런스 구조) -->
    <div class="textcols">
      <div class="col" set:html={toParagraphs(data.textEn)} />
      <div class="col kr" set:html={toParagraphs(data.textKr)} />
    </div>

    <!-- 마크다운 본문(선택) -->
    <div class="desc"><Content /></div>

    <!-- 미디어: 대표·보조·디테일 자료를 12열 위계로 편집 -->
    <div class="media">
      {
        media.map((m, index) =>
          m.type === "video" ? (
            <figure class={`block is-video ${defaultLayout(m, index)} ${m.align ? `align-${m.align}` : ""}`}>
              <div class="video" style={`aspect-ratio:${ratioValue[m.ratio] || "16 / 9"}`}>
                {embedURL(m.src).kind === "iframe" ? (
                  <iframe src={embedURL(m.src).src} allowfullscreen frameborder="0" loading="lazy" />
                ) : (
                  <video src={embedURL(m.src).src} controls playsinline />
                )}
              </div>
              {m.caption && <figcaption>{m.caption}</figcaption>}
            </figure>
          ) : (
            <figure class={`block ${defaultLayout(m, index)} ${m.align ? `align-${m.align}` : ""}`}>
              <img src={m.src} alt={m.caption || data.title} loading="lazy" />
              {m.caption && <figcaption>{m.caption}</figcaption>}
            </figure>
          )
        )
      }
      {
        media.length === 0 && (
          <>
            <figure class="block standard"><div class="ph" style="padding-bottom:130%"></div></figure>
            <figure class="block standard align-right"><div class="ph" style="padding-bottom:130%"></div></figure>
          </>
        )
      }
    </div>

    {
      data.sponsors && data.sponsors.length > 0 && (
        <div class="sponsors">
          <div class="sponsors-label">Exhibition Sponsors</div>
          <div class="sponsors-row">
            {data.sponsors.map((s) =>
              s.url ? (
                <a href={s.url} target="_blank" rel="noopener" class="sponsor">
                  {s.logo ? <img src={s.logo} alt={s.name} loading="lazy" /> : <span class="sponsor-name">{s.name}</span>}
                </a>
              ) : (
                <span class="sponsor">
                  {s.logo ? <img src={s.logo} alt={s.name} loading="lazy" /> : <span class="sponsor-name">{s.name}</span>}
                </span>
              )
            )}
          </div>
        </div>
      )
    }
  </div>

  <style>
    /* 레퍼런스: 메뉴 170px 옆, 본문 최대 1100px */
    #entry {
      width: calc(100% - 170px);
      max-width: 1100px;
      float: left;
      margin: 10px 0 0 0;
      position: relative;
    }
    .entry_title {
      font-size: 34px;
      font-weight: 300;
      line-height: 1.25;
      margin-bottom: 22px;
    }
    .meta { font-size: 18px; font-weight: 400; line-height: 1.6; color: #555; margin: 0 0 34px; }
    .meta .medium-type { display: block; color: #111; }
    .meta .medium-materials { display: block; margin-top: 8px; font-size: 16px; color: #777; }
    .series-link {
      display: inline-flex;
      flex-direction: column;
      gap: 2px;
      margin: -14px 0 30px;
      font-size: 14px;
      line-height: 1.4;
      color: #333;
    }
    .series-link span {
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #999;
    }
    .series-link:hover { color: var(--hover); }
    .series-link:hover span { color: var(--hover); }

    /* EN/KR 2단 — 본문 가독성만 개선(두께 400 / 16px / 넓은 줄간격) */
    .textcols::after { content: ""; display: block; clear: both; }
    .textcols .col {
      width: 46.5%;
      float: left;
      margin: 0 3% 30px 0;
      padding: 12px 0 0 0;
      border-top: 1px solid #000;
      font-size: 16px;
      font-weight: 400;
      line-height: 1.8;
      color: #555;
    }
    .textcols .col.kr { line-height: 1.85; }
    .textcols .col p { margin: 0 0 1em; }
    .textcols .col p:last-child { margin-bottom: 0; }

    .desc { font-size: 16px; font-weight: 400; line-height: 1.8; max-width: 640px; margin: 0 0 30px; }
    .desc :global(p) { margin: 0 0 1em; }

    /* 미디어 — 홈 그리드처럼 220/380/540 크기가 여백 있게 흐름 */
    .media {
      clear: both;
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 30px 12px;
      align-items: start;
    }

    /* 12열 그리드: 자료의 역할과 여백을 함께 조절한다. */
    .block { position: relative; grid-column: span 5; }
    .block.hero { grid-column: 1 / span 9; }
    .block.wide { grid-column: span 7; }
    .block.standard { grid-column: span 5; }
    .block.detail,
    .block.portrait { grid-column: span 4; }
    .block.hero.align-left { grid-column: 1 / span 9; }
    .block.hero.align-right { grid-column: 4 / span 9; }
    .block.wide.align-left { grid-column: 1 / span 7; }
    .block.wide.align-right { grid-column: 6 / span 7; }
    .block.standard.align-left { grid-column: 1 / span 5; }
    .block.standard.align-right { grid-column: 8 / span 5; }
    .block.detail.align-left,
    .block.portrait.align-left { grid-column: 1 / span 4; }
    .block.detail.align-right,
    .block.portrait.align-right { grid-column: 9 / span 4; }
    .block img { display: block; width: 100%; }
    .block .ph { background: #ececec; height: 0; }
    figure { margin: 0; }
    figcaption { font-size: 13px; color: #555; margin-top: 4px; }

    /* 영상: 비율에 맞춰 자동 크기 */
    .video { position: relative; width: 100%; background: #000; }
    .video iframe,
    .video video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }

    /* 전시 협력·후원 크레딧 — 작품 갤러리와 분리된 로고 스트립 */
    .sponsors {
      clear: both;
      position: relative;
      z-index: 1;
      margin: 10px 0 40px;
      padding-top: 24px;
      border-top: 1px solid #ddd;
    }
    .sponsors-label {
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 16px;
    }
    .sponsors-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 32px;
    }
    .sponsor { display: inline-flex; align-items: center; }
    .sponsor-name { font-size: 16px; color: #333; }
    .sponsor img {
      max-height: 40px;
      max-width: 140px;
      width: auto;
      display: block;
    }

    @media (max-width: 700px) {
      #entry { width: calc(100% - 20px); margin-left: 10px; }
      .textcols .col { width: 100%; margin-right: 0; float: none; }
      .block,
      .block.hero,
      .block.wide,
      .block.standard,
      .block.detail,
      .block.portrait { grid-column: 1 / -1; }
      .media { gap: 18px; }
    }
  </style>
</Base>
