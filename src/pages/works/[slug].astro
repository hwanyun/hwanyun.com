---
import { getCollection } from "astro:content"
import Base from "../../layouts/Base.astro"

export async function getStaticPaths() {
  const works = await getCollection("works", ({ data }) => !data.draft)
  return works.map((w) => ({ params: { slug: w.slug }, props: { work: w } }))
}

const { work } = Astro.props
const { data } = work
const { Content } = await work.render()
const yr = data.year ? ` (${data.year})` : ""

// 영상 URL을 임베드 가능한 형태로 정규화 (YouTube/Vimeo는 일반 링크를 붙여도 됨)
function embedURL(url: string): { kind: "iframe" | "file"; src: string } {
  const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]+)/)
  if (yt) return { kind: "iframe", src: `https://www.youtube.com/embed/${yt[1]}` }
  const vm = url.match(/vimeo\.com\/(?:video\/)?(\d+)/)
  if (vm) return { kind: "iframe", src: `https://player.vimeo.com/video/${vm[1]}` }
  if (/\.(mp4|webm|mov)(\?.*)?$/i.test(url)) return { kind: "file", src: url }
  return { kind: "iframe", src: url } // 이미 embed URL이면 그대로
}

const ratioValue: Record<string, string> = {
  "16:9": "16 / 9",
  "4:3": "4 / 3",
  "1:1": "1 / 1",
  "21:9": "21 / 9",
  "9:16": "9 / 16",
}

const media = data.media ?? []
const hasText = data.textEn || data.textKr

// 매체 표기: ";" 기준으로 종류 / 재료 분리 → 종류 한 줄, 재료 아래 줄
const mediumParts = (data.medium || "")
  .split(";")
  .map((s) => s.trim())
  .filter(Boolean)

// 배경 고스트 타이틀 (미디어 뒤에서 스크롤에 따라 드리프트)
const bigTitle = (data.title || "").toUpperCase()
const ghostLine = Array(8).fill(bigTitle).join(" · ")
const ghostRows = Array.from({ length: 7 })

// 아트디렉션 레이아웃: 미디어를 행으로 묶되,
// 꽉 차는 행은 양끝 정렬로 공간을 채우고, 덜 찬 행은 좌/우 교차 정렬로 비대칭 여백을 만든다.
const FRAC: Record<string, number> = { full: 1, half: 0.5, third: 1 / 3 }
type Row = { items: typeof media; align: "fill" | "left" | "right" }
const rows: Row[] = []
{
  let cur: typeof media = []
  let sum = 0
  const flush = () => {
    if (!cur.length) return
    rows.push({ items: cur, align: "fill" })
    cur = []
    sum = 0
  }
  for (const m of media) {
    const f = FRAC[m.width] ?? 1
    if (cur.length && sum + f > 1.02) flush()
    cur.push(m)
    sum += f
  }
  flush()
  // 정렬 주석: 꽉 찬 행은 fill, 덜 찬 행은 좌/우 번갈아
  let toggle = 0
  for (const r of rows) {
    const s = r.items.reduce((a, m) => a + (FRAC[m.width] ?? 1), 0)
    const full = s > 0.95 && r.items.length > 1
    const singleFull = r.items.length === 1 && (FRAC[r.items[0].width] ?? 1) >= 0.99
    if (full || singleFull) {
      r.align = "fill"
    } else {
      r.align = toggle % 2 === 0 ? "left" : "right"
      toggle++
    }
  }
}

// 설명 텍스트: 빈 줄은 문단 구분, 문단 안 줄바꿈은 공백으로 이어 자연스럽게 흐르게
function toParagraphs(text: string): string {
  return (text || "")
    .trim()
    .split(/\n\s*\n/)
    .map((p) => `<p>${p.replace(/\n/g, " ").trim()}</p>`)
    .join("")
}
---

<Base title={`HWANYUN — ${data.title}`}>
  <div id="entry">
    <div class="entry_title">{data.title}{yr}</div>

    {
      mediumParts.length > 0 && (
        <p class="meta">
          <span class="medium-type">{mediumParts[0]}</span>
          {mediumParts.length > 1 && (
            <span class="medium-materials">{mediumParts.slice(1).join("; ")}</span>
          )}
        </p>
      )
    }

    <!-- EN / KR 2단 텍스트 — 글자가 없어도 항상 2단 (레퍼런스 구조) -->
    <div class="textcols">
      <div class="col" set:html={toParagraphs(data.textEn)} />
      <div class="col kr" set:html={toParagraphs(data.textKr)} />
    </div>

    <!-- 마크다운 본문(선택) -->
    <div class="desc"><Content /></div>

    <!-- 미디어: 이미지/영상을 폭을 달리하며 흐름 -->
    <div class="media">
      {
        bigTitle && (
          <div class="ghost" aria-hidden="true">
            {ghostRows.map((_, r) => (
              <div class="ghost-row" data-dir={r % 2 === 0 ? 1 : -1}>
                {ghostLine}
              </div>
            ))}
          </div>
        )
      }
      {
        rows.map((row) => (
          <div class={`mrow ${row.align}`}>
            {row.items.map((m) =>
              m.type === "video" ? (
                <figure class={`block w-${m.width}`}>
                  <div class="video" style={`aspect-ratio:${ratioValue[m.ratio] || "16 / 9"}`}>
                    {embedURL(m.src).kind === "iframe" ? (
                      <iframe src={embedURL(m.src).src} allowfullscreen frameborder="0" loading="lazy" />
                    ) : (
                      <video src={embedURL(m.src).src} controls playsinline />
                    )}
                  </div>
                  {m.caption && <figcaption>{m.caption}</figcaption>}
                </figure>
              ) : (
                <figure class={`block w-${m.width}`}>
                  <img src={m.src} alt={m.caption || data.title} loading="lazy" />
                  {m.caption && <figcaption>{m.caption}</figcaption>}
                </figure>
              )
            )}
          </div>
        ))
      }
      {
        media.length === 0 && (
          <div class="mrow fill">
            <figure class="block w-half"><div class="ph" style="padding-bottom:130%"></div></figure>
            <figure class="block w-half"><div class="ph" style="padding-bottom:130%"></div></figure>
          </div>
        )
      }
    </div>
  </div>

  <script is:inline>
    ;(function () {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return
      var rows = document.querySelectorAll(".ghost-row")
      var media = document.querySelector(".media")
      if (!rows.length || !media) return
      var ticking = false
      function update() {
        var p = window.innerHeight - media.getBoundingClientRect().top
        for (var i = 0; i < rows.length; i++) {
          var dir = parseFloat(rows[i].getAttribute("data-dir")) || 1
          var speed = 0.14 + (i % 3) * 0.05
          rows[i].style.transform = "translateX(" + p * speed * dir * -1 + "px)"
        }
        ticking = false
      }
      function onScroll() {
        if (!ticking) { window.requestAnimationFrame(update); ticking = true }
      }
      window.addEventListener("scroll", onScroll, { passive: true })
      window.addEventListener("resize", onScroll)
      update()
    })()
  </script>

  <style>
    /* 레퍼런스: 메뉴 170px 옆, 본문 최대 1100px */
    #entry {
      width: calc(100% - 170px);
      max-width: 1100px;
      float: left;
      margin: 10px 0 0 0;
      position: relative;
    }
    .entry_title {
      font-size: 34px;
      font-weight: 300;
      line-height: 1.25;
      margin-bottom: 22px;
    }
    .meta { font-size: 18px; font-weight: 400; line-height: 1.6; color: #555; margin: 0 0 34px; }
    .meta .medium-type { display: block; color: #111; }
    .meta .medium-materials { display: block; margin-top: 8px; font-size: 16px; color: #777; }

    /* EN/KR 2단 — 본문 가독성만 개선(두께 400 / 16px / 넓은 줄간격) */
    .textcols::after { content: ""; display: block; clear: both; }
    .textcols .col {
      width: 46.5%;
      float: left;
      margin: 0 3% 30px 0;
      padding: 12px 0 0 0;
      border-top: 1px solid #000;
      font-size: 16px;
      font-weight: 400;
      line-height: 1.8;
      color: #555;
    }
    .textcols .col.kr { line-height: 1.85; }
    .textcols .col p { margin: 0 0 1em; }
    .textcols .col p:last-child { margin-bottom: 0; }

    .desc { font-size: 16px; font-weight: 400; line-height: 1.8; max-width: 640px; margin: 0 0 30px; }
    .desc :global(p) { margin: 0 0 1em; }

    /* 미디어 — 홈 그리드처럼 220/380/540 크기가 여백 있게 흐름 */
    .media { clear: both; position: relative; }

    /* 배경 고스트 타이틀 (여백 사이로 은은히 비치며 스크롤에 드리프트) */
    .ghost {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 20px 0;
      pointer-events: none;
    }
    .ghost-row {
      white-space: nowrap;
      text-align: center;
      font-size: clamp(64px, 12vw, 150px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1;
      color: rgba(0, 0, 0, 0.09);
      will-change: transform;
    }
    @media (prefers-reduced-motion: reduce) {
      .ghost-row { transform: none !important; }
    }

    /* 아트디렉션 행: 꽉 찬 행은 양끝, 덜 찬 행은 좌/우로 몰아 비대칭 여백 */
    .mrow {
      display: flex;
      align-items: flex-start;
      gap: 3%;
      margin: 0 0 26px;
      position: relative;
      z-index: 1;
    }
    .mrow.fill { justify-content: space-between; }
    .mrow.left { justify-content: flex-start; }
    .mrow.right { justify-content: flex-end; }
    .block { position: relative; }
    .block.w-full { width: 100%; }
    .block.w-half { width: 48.5%; }
    .block.w-third { width: 31.5%; }
    .block img { display: block; width: 100%; }
    .block .ph { background: #ececec; height: 0; }
    figure { margin: 0; }
    figcaption { font-size: 13px; color: #555; margin-top: 4px; }

    /* 영상: 비율에 맞춰 자동 크기 */
    .video { position: relative; width: 100%; background: #000; }
    .video iframe,
    .video video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }

    @media (max-width: 700px) {
      #entry { width: calc(100% - 20px); margin-left: 10px; }
      .textcols .col { width: 100%; margin-right: 0; float: none; }
      .mrow { flex-direction: column; gap: 16px; }
      .block,
      .block.w-full,
      .block.w-half,
      .block.w-third { width: 100%; }
    }
  </style>
</Base>
