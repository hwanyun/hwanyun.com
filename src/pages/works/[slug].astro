---
import { getCollection } from "astro:content"
import Base from "../../layouts/Base.astro"

export async function getStaticPaths() {
  const works = await getCollection("works", ({ data }) => !data.draft)
  return works.map((w) => ({ params: { slug: w.slug }, props: { work: w } }))
}

const { work } = Astro.props
const { data } = work
const { Content } = await work.render()
const yr = data.year ? ` (${data.year})` : ""
const allWorks = await getCollection("works", ({ data }) => !data.draft)
const allSounds = await getCollection("sounds", ({ data }) => !data.draft)
const seriesWorks = data.series
  ? allWorks
      .filter((item) => item.data.series?.id === data.series?.id)
      .sort((a, b) => a.data.order - b.data.order)
  : []
const relatedSounds = allSounds
  .filter((sound) => sound.data.works.includes(work.slug))
  .sort((a, b) => a.data.order - b.data.order)

// 영상 URL을 임베드 가능한 형태로 정규화 (YouTube/Vimeo는 일반 링크를 붙여도 됨)
function embedURL(url: string): { kind: "iframe" | "file"; src: string } {
  const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]+)/)
  if (yt) return { kind: "iframe", src: `https://www.youtube.com/embed/${yt[1]}` }
  const vm = url.match(/vimeo\.com\/(?:video\/)?(\d+)(?:[?&]h=([\w]+))?/)
  if (vm) {
    const hash = vm[2] ? `?h=${vm[2]}` : ""
    return { kind: "iframe", src: `https://player.vimeo.com/video/${vm[1]}${hash}` }
  }
  if (/\.(mp4|webm|mov)(\?.*)?$/i.test(url)) return { kind: "file", src: url }
  return { kind: "iframe", src: url } // 이미 embed URL이면 그대로
}

const ratioValue: Record<string, string> = {
  "16:9": "16 / 9",
  "4:3": "4 / 3",
  "1:1": "1 / 1",
  "21:9": "21 / 9",
  "9:16": "9 / 16",
}

const media = data.media ?? []
const galleryMedia = data.mediaFirst ? media.slice(1) : media
const hasText = data.textEn || data.textKr

// 매체 표기: ";" 기준으로 종류 / 재료 분리 → 종류 한 줄, 재료 아래 줄
const mediumParts = (data.medium || "")
  .split(";")
  .map((s) => s.trim())
  .filter(Boolean)

const defaultLayout = (m: (typeof media)[number], index: number) => {
  // 공통 편집 규칙: 첫 장은 대표 이미지, full은 주요 기록,
  // third·세로 영상은 보조/디테일로 읽히게 한다.
  if (m.layout) return m.layout
  if (index === 0) return "hero"
  if (m.type === "video" && m.ratio === "9:16") return "portrait"
  if (m.width === "full") return "wide"
  if (m.width === "third") return "detail"
  return "standard"
}

// 설명 텍스트: 빈 줄은 문단 구분, 문단 안 줄바꿈은 공백으로 이어 자연스럽게 흐르게
function toParagraphs(text: string): string {
  return (text || "")
    .trim()
    .split(/\n\s*\n/)
    .map((p) => `<p>${p.replace(/\n/g, " ").trim()}</p>`)
    .join("")
}
---

<Base title={`HWANYUN — ${data.title}`}>
  <div id="entry">
    <div class="entry_title">{data.title}{yr}</div>

    {
      mediumParts.length > 0 && (
        <p class="meta">
          <span class="medium-type">{mediumParts[0]}</span>
          {mediumParts.length > 1 && (
            <span class="medium-materials">{mediumParts.slice(1).join("; ")}</span>
          )}
        </p>
      )
    }

    {
      data.series && seriesWorks.length > 1 && (
        <nav class="series-link" aria-label={`${data.series.label} series`}>
          <span>Part of the series</span>
          <div class="series-members">
            {seriesWorks.map((item) =>
              item.slug === work.slug ? (
                <span class="series-current" aria-current="page">{item.data.title}</span>
              ) : (
                <a href={`/works/${item.slug}/`}>{item.data.title}</a>
              )
            )}
          </div>
        </nav>
      )
    }

    {
      data.mediaFirst && media[0] && (
        <div class="media media--lead">
          {media[0].type === "video" ? (
            <figure class={`block is-video ${defaultLayout(media[0], 0)} ${media[0].align ? `align-${media[0].align}` : ""}`}>
              <div class="video" style={`aspect-ratio:${ratioValue[media[0].ratio] || "16 / 9"}`}>
                <button
                  class="video-trigger"
                  type="button"
                  data-video-src={embedURL(media[0].src).src}
                  data-video-kind={embedURL(media[0].src).kind}
                  data-video-ratio={ratioValue[media[0].ratio] || "16 / 9"}
                  data-video-title={media[0].caption || data.title}
                  aria-label={`Play ${media[0].caption || data.title}`}
                >
                  {embedURL(media[0].src).kind === "iframe" ? (
                    <span class="video-preview video-preview--embed" aria-hidden="true">VIDEO</span>
                  ) : (
                    <video class="video-preview" src={embedURL(media[0].src).src} muted playsinline preload="metadata" aria-hidden="true" />
                  )}
                  <span class="video-play" aria-hidden="true"><span></span></span>
                </button>
              </div>
              {media[0].caption && <figcaption>{media[0].caption}</figcaption>}
              {(media[0].noteEn || media[0].noteKr) && (
                <div class="media-note">
                  {media[0].noteLabel && <div class="media-note-label">{media[0].noteLabel}</div>}
                  <div class="media-note-cols">
                    <p>{media[0].noteEn}</p>
                    <p>{media[0].noteKr}</p>
                  </div>
                </div>
              )}
            </figure>
          ) : (
            <figure class={`block ${defaultLayout(media[0], 0)} ${media[0].align ? `align-${media[0].align}` : ""}`}>
              <img src={media[0].src} alt={media[0].caption || data.title} loading="lazy" />
              {media[0].caption && <figcaption>{media[0].caption}</figcaption>}
            </figure>
          )}
        </div>
      )
    }

    <!-- EN / KR 2단 텍스트 — 글자가 없어도 항상 2단 (레퍼런스 구조) -->
    <div class="textcols">
      <div class="col" set:html={toParagraphs(data.textEn)} />
      <div class="col kr" set:html={toParagraphs(data.textKr)} />
    </div>

    <!-- 마크다운 본문(선택) -->
    <div class="desc"><Content /></div>

    {
      data.processNote && (data.processNote.textEn || data.processNote.textKr) && (
        <aside class="process-note" aria-label={data.processNote.label}>
          <div class="process-note-cols">
            {data.processNote.textEn && <p>{data.processNote.textEn}</p>}
            {data.processNote.textKr && <p lang="ko">{data.processNote.textKr}</p>}
          </div>
        </aside>
      )
    }

    <!-- 미디어: 대표·보조·디테일 자료를 12열 위계로 편집 -->
    <div class="media">
      {
        galleryMedia.map((m, index) =>
          m.type === "video" ? (
            <figure class={`block is-video ${defaultLayout(m, index)} ${m.align ? `align-${m.align}` : ""}`}>
              <div class="video" style={`aspect-ratio:${ratioValue[m.ratio] || "16 / 9"}`}>
                <button
                  class="video-trigger"
                  type="button"
                  data-video-src={embedURL(m.src).src}
                  data-video-kind={embedURL(m.src).kind}
                  data-video-ratio={ratioValue[m.ratio] || "16 / 9"}
                  data-video-title={m.caption || data.title}
                  aria-label={`Play ${m.caption || data.title}`}
                >
                  {embedURL(m.src).kind === "iframe" ? (
                    <span class="video-preview video-preview--embed" aria-hidden="true">VIDEO</span>
                  ) : (
                    <video class="video-preview" src={embedURL(m.src).src} muted playsinline preload="metadata" aria-hidden="true" />
                  )}
                  <span class="video-play" aria-hidden="true"><span></span></span>
                </button>
              </div>
              {m.caption && <figcaption>{m.caption}</figcaption>}
              {(m.noteEn || m.noteKr) && (
                <div class="media-note">
                  {m.noteLabel && <div class="media-note-label">{m.noteLabel}</div>}
                  <div class="media-note-cols">
                    <p>{m.noteEn}</p>
                    <p>{m.noteKr}</p>
                  </div>
                </div>
              )}
            </figure>
          ) : (
            <figure class={`block ${defaultLayout(m, index)} ${m.align ? `align-${m.align}` : ""}`}>
              <img src={m.src} alt={m.caption || data.title} loading="lazy" />
              {m.caption && <figcaption>{m.caption}</figcaption>}
            </figure>
          )
        )
      }
      {
        media.length === 0 && (
          <>
            <figure class="block standard"><div class="ph" style="padding-bottom:130%"></div></figure>
            <figure class="block standard align-right"><div class="ph" style="padding-bottom:130%"></div></figure>
          </>
        )
      }
    </div>

    <div class="post-gallery-divider" aria-hidden="true"></div>

    {
      relatedSounds.length > 0 && (
        <section class="related-sounds" aria-labelledby="related-sounds-title">
          <div id="related-sounds-title" class="related-sounds-label">Related sound recordings</div>
          <div class="related-sounds-list">
            {relatedSounds.map((sound) => (
              <a href={`/sound/#sound-${sound.slug}`}>
                <span>{sound.data.title}</span>
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      data.exhibition && (
        <div class="exhibition-credit">
          {data.exhibition.label && <div class="exhibition-label">{data.exhibition.label}</div>}
          <div class="exhibition-title">
            {data.exhibition.titleEn && <span>{data.exhibition.titleEn}</span>}
            {data.exhibition.titleKr && <span lang="ko">{data.exhibition.titleKr}</span>}
            {(data.exhibition.venue || data.exhibition.year) && (
              <span class="exhibition-meta">{[data.exhibition.venue, data.exhibition.year].filter(Boolean).join(", ")}</span>
            )}
          </div>
        </div>
      )
    }

    {
      data.externalLinks && data.externalLinks.length > 0 && (
        <section class="external-links" aria-label="Further reading">
          <div class="external-links-label">Further Reading</div>
          <div class="external-links-list">
            {data.externalLinks.map((link) => (
              <a href={link.url} target="_blank" rel="noopener">
                <span>{link.title}</span>
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      data.sponsors && data.sponsors.length > 0 && (
        <div class="sponsors">
          <div class="sponsors-label">Exhibition Sponsors</div>
          <div class="sponsors-row">
            {data.sponsors.map((s) =>
              s.url ? (
                <a href={s.url} target="_blank" rel="noopener" class="sponsor">
                  {s.logo ? <img src={s.logo} alt={s.name} loading="lazy" /> : <span class="sponsor-name">{s.name}</span>}
                </a>
              ) : (
                <span class="sponsor">
                  {s.logo ? <img src={s.logo} alt={s.name} loading="lazy" /> : <span class="sponsor-name">{s.name}</span>}
                </span>
              )
            )}
          </div>
        </div>
      )
    }
  </div>

  <div id="video-lightbox" class="video-lightbox" hidden aria-hidden="true">
    <div class="video-lightbox-backdrop" data-video-close></div>
    <section class="video-dialog" role="dialog" aria-modal="true" aria-labelledby="video-lightbox-title">
      <div class="video-dialog-header">
        <p id="video-lightbox-title"></p>
        <button class="video-close" type="button" data-video-close aria-label="Close video">×</button>
      </div>
      <div id="video-lightbox-frame"></div>
    </section>
  </div>

  <script>
    const initVideoLightbox = () => {
      const lightbox = document.querySelector<HTMLDivElement>("#video-lightbox")
      const frame = document.querySelector<HTMLDivElement>("#video-lightbox-frame")
      const title = document.querySelector<HTMLParagraphElement>("#video-lightbox-title")
      let lastTrigger: HTMLButtonElement | null = null

    const closeVideo = () => {
      if (!lightbox || !frame) return
      const video = frame.querySelector("video")
      if (video) {
        video.pause()
        video.removeAttribute("src")
        video.load()
      }
      frame.replaceChildren()
      lightbox.hidden = true
      lightbox.setAttribute("aria-hidden", "true")
      document.body.classList.remove("video-open")
      lastTrigger?.focus()
    }

    const openVideo = (trigger: HTMLButtonElement) => {
      if (!lightbox || !frame || !title) return
      const { videoSrc, videoKind, videoRatio, videoTitle } = trigger.dataset
      if (!videoSrc) return

      lastTrigger = trigger
      title.textContent = videoTitle || "Video"
      const playerFrame = document.createElement("div")
      playerFrame.className = "video-lightbox-frame"

      if (videoKind === "file") {
        playerFrame.classList.add("is-file")
        const video = document.createElement("video")
        video.src = videoSrc
        video.controls = true
        video.autoplay = true
        video.playsInline = true
        playerFrame.append(video)
      } else {
        playerFrame.style.aspectRatio = videoRatio || "16 / 9"
        const iframe = document.createElement("iframe")
        iframe.src = `${videoSrc}${videoSrc.includes("?") ? "&" : "?"}autoplay=1`
        iframe.allow = "autoplay; fullscreen; picture-in-picture"
        iframe.allowFullscreen = true
        iframe.title = videoTitle || "Video"
        playerFrame.append(iframe)
      }

      frame.replaceChildren(playerFrame)
      lightbox.hidden = false
      lightbox.setAttribute("aria-hidden", "false")
      document.body.classList.add("video-open")
      lightbox.querySelector<HTMLButtonElement>(".video-close")?.focus()
    }

      document.querySelectorAll<HTMLButtonElement>(".video-trigger").forEach((trigger) => {
        trigger.addEventListener("click", () => openVideo(trigger))
      })
      lightbox?.querySelectorAll<HTMLElement>("[data-video-close]").forEach((control) => {
        control.addEventListener("click", closeVideo)
      })

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && lightbox && !lightbox.hidden) closeVideo()
      })
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initVideoLightbox, { once: true })
    } else {
      initVideoLightbox()
    }
  </script>

  <style>
    /* 레퍼런스: 메뉴 170px 옆, 본문 최대 1100px */
    #entry {
      width: calc(100% - 170px);
      max-width: 1100px;
      float: left;
      margin: 10px 0 0 0;
      position: relative;
    }
    .entry_title {
      font-size: 34px;
      font-weight: 300;
      line-height: 1.25;
      margin-bottom: 22px;
    }
    .meta { font-size: 18px; font-weight: 400; line-height: 1.6; color: #555; margin: 0 0 34px; }
    .meta .medium-type { display: block; color: #111; }
    .meta .medium-materials { display: block; margin-top: 8px; font-size: 16px; color: #777; }
    .series-link {
      display: inline-flex;
      flex-direction: column;
      gap: 2px;
      margin: -14px 0 30px;
      font-size: 14px;
      line-height: 1.4;
      color: #333;
    }
    .series-link span {
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #999;
    }
    .series-members { display: flex; flex-wrap: wrap; gap: 0 10px; }
    .series-members a,
    .series-current { color: #333; }
    .series-members a + a::before,
    .series-members a + .series-current::before,
    .series-current + a::before { content: "·"; margin-right: 10px; color: #aaa; }
    .series-members a:hover { color: var(--hover); }
    .series-link:hover > span { color: var(--hover); }

    /* EN/KR 2단 — 본문 가독성만 개선(두께 400 / 16px / 넓은 줄간격) */
    .textcols::after { content: ""; display: block; clear: both; }
    .textcols .col {
      width: 46.5%;
      float: left;
      margin: 0 3% 30px 0;
      padding: 12px 0 0 0;
      border-top: 1px solid #000;
      font-size: 16px;
      font-weight: 400;
      line-height: 1.8;
      color: #555;
    }
    .textcols .col.kr { line-height: 1.85; }
    .textcols .col p { margin: 0 0 1em; }
    .textcols .col p:last-child { margin-bottom: 0; }

    .desc { font-size: 16px; font-weight: 400; line-height: 1.8; max-width: 640px; margin: 0 0 30px; }
    .desc :global(p) { margin: 0 0 1em; }
    .process-note {
      clear: both;
      margin: -4px 0 42px;
      color: #999;
    }
    .process-note-cols { display: grid; grid-template-columns: 46.5% 46.5%; column-gap: 3%; }
    .process-note p { margin: 0; font-size: 14px; line-height: 1.75; }

    /* 미디어 — 홈 그리드처럼 220/380/540 크기가 여백 있게 흐름 */
    .media {
      clear: both;
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 30px 12px;
      align-items: start;
    }
    .media--lead { margin: 0 0 42px; }
    .post-gallery-divider {
      clear: both;
      margin: 72px 0 0;
      border-top: 1px solid #ddd;
    }

    /* 12열 그리드: 자료의 역할과 여백을 함께 조절한다. */
    .block { position: relative; grid-column: span 5; }
    .block.hero { grid-column: 1 / span 9; }
    .block.wide { grid-column: span 7; }
    .block.standard { grid-column: span 5; }
    .block.detail,
    .block.portrait { grid-column: span 4; }
    .block.hero.align-left { grid-column: 1 / span 9; }
    .block.hero.align-right { grid-column: 4 / span 9; }
    .block.wide.align-left { grid-column: 1 / span 7; }
    .block.wide.align-right { grid-column: 6 / span 7; }
    .block.standard.align-left { grid-column: 1 / span 5; }
    .block.standard.align-right { grid-column: 8 / span 5; }
    .block.detail.align-left,
    .block.portrait.align-left { grid-column: 1 / span 4; }
    .block.detail.align-right,
    .block.portrait.align-right { grid-column: 9 / span 4; }
    .block img { display: block; width: 100%; }
    .block .ph { background: #ececec; height: 0; }
    figure { margin: 0; }
    figcaption { font-size: 13px; color: #555; margin-top: 4px; }
    .media-note {
      margin-top: 18px;
      padding-top: 12px;
      border-top: 1px solid #d8d8d8;
      color: #555;
    }
    .media-note-label {
      margin-bottom: 10px;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #999;
    }
    .media-note-cols { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; }
    .media-note p { margin: 0; font-size: 14px; line-height: 1.7; }

    /* 영상: 첫 장면은 그리드에 남기고, 재생은 집중형 뷰어에서 연다. */
    .video { position: relative; width: 100%; background: #000; }
    .video-trigger {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      padding: 0;
      border: 0;
      background: #000;
      cursor: pointer;
      overflow: hidden;
    }
    .video-preview {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      opacity: .9;
      transition: opacity .22s ease, transform .35s ease;
    }
    .video-preview--embed {
      display: grid;
      place-items: center;
      color: #777;
      font-size: 11px;
      letter-spacing: .14em;
    }
    .video-trigger:hover .video-preview,
    .video-trigger:focus-visible .video-preview { opacity: .65; transform: scale(1.015); }
    .video-trigger:focus-visible { outline: 1px solid #fff; outline-offset: 3px; }
    .video-play {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 50px;
      height: 50px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(255, 255, 255, .9);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      transition: transform .22s ease, background .22s ease;
    }
    .video-play span {
      width: 0;
      height: 0;
      margin-left: 3px;
      border-top: 6px solid transparent;
      border-bottom: 6px solid transparent;
      border-left: 9px solid #fff;
    }
    .video-trigger:hover .video-play,
    .video-trigger:focus-visible .video-play { background: rgba(0, 0, 0, .42); transform: translate(-50%, -50%) scale(1.08); }
    .video-lightbox {
      position: fixed;
      z-index: 1000;
      inset: 0;
      display: grid;
      place-items: center;
      padding: 28px;
    }
    .video-lightbox[hidden] { display: none; }
    .video-lightbox-backdrop { position: absolute; inset: 0; background: rgba(0, 0, 0, .94); }
    .video-dialog { position: relative; width: min(100%, 1180px); color: #fff; }
    .video-dialog-header { display: flex; justify-content: space-between; align-items: center; gap: 24px; margin: 0 0 12px; }
    .video-dialog-header p { margin: 0; font-size: 13px; color: rgba(255, 255, 255, .72); }
    .video-close {
      width: 32px;
      height: 32px;
      padding: 0;
      border: 0;
      background: transparent;
      color: #fff;
      font-size: 29px;
      font-weight: 200;
      line-height: 1;
      cursor: pointer;
    }
    .video-close:focus-visible { outline: 1px solid #fff; outline-offset: 2px; }
    .video-lightbox-frame { position: relative; width: 100%; max-height: calc(100vh - 110px); background: #000; }
    .video-lightbox-frame iframe,
    .video-lightbox-frame video {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      border: 0;
    }
    .video-lightbox-frame.is-file video {
      position: relative;
      height: auto;
      max-height: calc(100vh - 110px);
      object-fit: contain;
    }
    :global(body.video-open) { overflow: hidden; }

    /* 전시 맥락과 후원 크레딧은 작품 갤러리와 분리해 표기 */
    .exhibition-credit {
      clear: both;
      position: relative;
      z-index: 1;
      margin: 26px 0 0;
      padding-top: 0;
    }
    .related-sounds {
      clear: both;
      position: relative;
      z-index: 1;
      margin: 24px 0 0;
      padding-top: 0;
