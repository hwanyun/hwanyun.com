---
import Base from "../layouts/Base.astro"
import WorkGrid from "../components/WorkGrid.astro"
---

<Base title="HWANYUN">
  <nav slot="menu"></nav>

  <section class="hero" aria-labelledby="hero-title">
    <canvas id="particle-canvas" class="hero__field" aria-hidden="true"></canvas>
    <h1 id="hero-title" class="sr-only">HWANYUN</h1>
  </section>

  <section id="works" class="work-archive" aria-label="Selected works">
    <WorkGrid current="home" />
  </section>

  <script>
    const hero = document.querySelector<HTMLElement>(".hero")
    const canvas = document.querySelector<HTMLCanvasElement>("#particle-canvas")
    const context = canvas?.getContext("2d")

    if (hero && canvas && context) {
      type Particle = {
        x: number; y: number; vx: number; vy: number
        sphereX: number; sphereY: number; sphereZ: number
        targetX: number; targetY: number
      }
      let particles: Particle[] = []
      let isInside = false
      let width = 0
      let height = 0
      let pixelRatio = 1

      const createTargets = () => {
        const sample = document.createElement("canvas")
        const sampleContext = sample.getContext("2d")!
        sample.width = width
        sample.height = height
        const fontSize = Math.min(width * .145, 180)
        sampleContext.font = `600 ${fontSize}px Arial, sans-serif`
        sampleContext.textAlign = "center"
        sampleContext.textBaseline = "middle"
        sampleContext.fillStyle = "#fff"
        sampleContext.fillText("HWANYUN", width / 2, height / 2)
        const pixels = sampleContext.getImageData(0, 0, width, height).data
        const targets: Array<[number, number]> = []
        const step = Math.max(3, Math.round(width / 460))
        for (let y = 0; y < height; y += step) {
          for (let x = 0; x < width; x += step) {
            if (pixels[(y * width + x) * 4 + 3] > 0) targets.push([x, y])
          }
        }
        return targets
      }

      const resize = () => {
        const rect = hero.getBoundingClientRect()
        pixelRatio = Math.min(window.devicePixelRatio || 1, 2)
        width = Math.round(rect.width)
        height = Math.round(rect.height)
        canvas.width = width * pixelRatio
        canvas.height = height * pixelRatio
        canvas.style.width = `${width}px`
        canvas.style.height = `${height}px`
        context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0)
        const targets = createTargets()
        const count = Math.min(3200, Math.max(2400, targets.length * 2))
        particles = Array.from({ length: count }, (_, index) => {
          const targetIndex = Math.floor(index / count * targets.length)
          const [targetX, targetY] = targets[targetIndex] || [width / 2, height / 2]
          const sphereY = 1 - (index / (count - 1)) * 2
          const sphereRadius = Math.sqrt(1 - sphereY * sphereY)
          const sphereAngle = index * 2.399963229728653
          const sphereX = Math.cos(sphereAngle) * sphereRadius
          const sphereZ = Math.sin(sphereAngle) * sphereRadius
          return {
            x: width / 2,
            y: height / 2,
            vx: 0, vy: 0,
            sphereX,
            sphereY,
            sphereZ,
            targetX, targetY,
          }
        })
      }

      const draw = (time: number) => {
        context.clearRect(0, 0, width, height)
        const centerX = width / 2
        const centerY = height / 2
        const size = Math.min(width, height)
        const haze = context.createRadialGradient(centerX, centerY, 0, centerX, centerY, size * .5)
        haze.addColorStop(0, "rgba(255, 255, 255, .025)")
        haze.addColorStop(1, "rgba(7, 8, 10, 0)")
        context.fillStyle = haze
        context.fillRect(0, 0, width, height)

        const rotation = time * .00028
        const tilt = -.22
        const cosRotation = Math.cos(rotation)
        const sinRotation = Math.sin(rotation)
        const cosTilt = Math.cos(tilt)
        const sinTilt = Math.sin(tilt)
        const globeRadius = size * .49

        for (const particle of particles) {
          const rotatedX = particle.sphereX * cosRotation - particle.sphereZ * sinRotation
          const rotatedZ = particle.sphereX * sinRotation + particle.sphereZ * cosRotation
          const rotatedY = particle.sphereY * cosTilt - rotatedZ * sinTilt
          const depth = particle.sphereY * sinTilt + rotatedZ * cosTilt
          const perspective = 2.8 / (3.3 - depth)
          const driftX = centerX + rotatedX * globeRadius * perspective
          const driftY = centerY + rotatedY * globeRadius * perspective
          const destinationX = isInside ? particle.targetX : driftX
          const destinationY = isInside ? particle.targetY : driftY
          particle.vx = (particle.vx + (destinationX - particle.x) * (isInside ? .025 : .024)) * .8
          particle.vy = (particle.vy + (destinationY - particle.y) * (isInside ? .025 : .024)) * .8
          particle.x += particle.vx
          particle.y += particle.vy
          context.beginPath()
          const pointSize = isInside ? 1.1 : .52 + (depth + 1) * .48
          const brightness = isInside ? .96 : .26 + (depth + 1) * .34
          context.arc(particle.x, particle.y, pointSize, 0, Math.PI * 2)
          context.fillStyle = `rgba(255, 255, 255, ${brightness})`
          context.fill()
        }
        requestAnimationFrame(draw)
      }

      hero.addEventListener("pointermove", (event) => {
        const rect = hero.getBoundingClientRect()
        const x = event.clientX - rect.left - width / 2
        const y = event.clientY - rect.top - height / 2
        isInside = Math.hypot(x, y) < Math.min(width, height) * .48
      })
      hero.addEventListener("pointerleave", () => { isInside = false })
      window.addEventListener("resize", resize)
      resize()
      requestAnimationFrame(draw)
    }
  </script>

  <style>
    :global(body) { background: #fff; }
    .hero {
      position: relative;
      display: grid;
      min-height: 100svh;
      overflow: hidden;
      place-items: center;
      color: #f7f7f3;
      background: #0a0b0d;
      isolation: isolate;
    }
    .hero__field { position: absolute; inset: 0; width: 100%; height: 100%; }
    .work-archive { scroll-margin-top: 0; }
    .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; }
  </style>
</Base>
