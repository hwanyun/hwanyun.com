---
import { getCollection } from "astro:content"
import Base from "../layouts/Base.astro"

const sounds = (await getCollection("sounds", ({ data }) => !data.draft)).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
)
const sections = [
  { id: "works", title: "Sound Works", note: "Installations, spatial works, and their listening versions." },
  { id: "scores", title: "Scores & Collaborations", note: "Sound composed for fashion, performance, and shared projects." },
  { id: "archive", title: "Studies & Archive", note: "Field recordings, sketches, and independent recordings." },
]
const grouped = (id: string) => sounds.filter((sound) => sound.data.section === id)
const releases = (id: string) => {
  const items = grouped(id)
  return Array.from(new Map(items.map((item) => [item.data.project || item.data.title, item])).values()).map((lead) => ({
    title: lead.data.project || lead.data.title,
    tracks: items.filter((item) => (item.data.project || item.data.title) === (lead.data.project || lead.data.title)),
  }))
}
---

<Base title="HWANYUN — Sound" current="sound">
  <video id="listening-backdrop" muted loop playsinline aria-hidden="true"></video>
  <div id="backdrop-title" aria-live="polite"></div>
  <main id="sound-archive">
    <header class="archive-head">
      <p class="eyebrow">HWANYUN / LISTENING ARCHIVE</p>
      <h1>Sound</h1>
      <p class="intro">A selection of sound works, scores, and recordings. Each entry remains connected to the circumstance in which it was made.</p>
    </header>

    {sections.map((section) => (
      <section class="section" aria-labelledby={`${section.id}-title`}>
        <div class="section-head">
          <h2 id={`${section.id}-title`}>{section.title}</h2>
          <p>{section.note}</p>
        </div>
        <ol class="release-list">
          {releases(section.id).map((release, index) => (
            <li class="release">
              <details>
                <summary>
                  <span class="number">{String(index + 1).padStart(2, "0")}</span>
                  <strong>{release.title}</strong>
                  <span class="release-count">{release.tracks.length} {release.tracks.length === 1 ? "recording" : "recordings"}</span>
                  <span class={`moving-tag ${release.tracks.some((sound) => sound.data.backdrop) ? "" : "is-empty"}`}>Moving image</span>
                  <span class="expand" aria-hidden="true">+</span>
                </summary>
                <ol class="tracklist">
                  {release.tracks.map((sound) => (
                    <li id={`sound-${sound.slug}`} class="track" data-title={sound.data.title}>
                      <span>{sound.data.title}</span>
                      <span class="track-meta">
                        {sound.data.year && <span>{sound.data.year}</span>}
                        {sound.data.backdrop && <span class="moving-tag">Audio + moving image</span>}
                      </span>
                      {sound.data.audio && <button class="track-control" type="button" data-audio={sound.data.audio} data-backdrop={sound.data.backdrop} aria-label={`${sound.data.title} 재생`}><span aria-hidden="true"></span></button>}
                    </li>
                  ))}
                </ol>
              </details>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </main>

  <audio id="archive-player" preload="metadata"></audio>
  <div id="player-bar" hidden>
    <div class="player-track"><span class="now-playing"></span><span class="player-time">0:00 / 0:00</span></div>
    <div class="player-actions">
      <button type="button" class="pause" aria-label="일시정지"><span aria-hidden="true"></span></button>
      <button type="button" class="stop" aria-label="정지"><span aria-hidden="true"></span></button>
    </div>
    <div class="progress" role="progressbar" aria-label="재생 진행" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"><span></span></div>
  </div>

  <script is:inline>
    const player = document.getElementById("archive-player")
    const bar = document.getElementById("player-bar")
    const now = bar.querySelector(".now-playing")
    const time = bar.querySelector(".player-time")
    const progress = bar.querySelector(".progress")
    const progressFill = progress.querySelector("span")
    const pause = bar.querySelector(".pause")
    const stop = bar.querySelector(".stop")
    const backdrop = document.getElementById("listening-backdrop")
    const backdropTitle = document.getElementById("backdrop-title")
    let activeButton = null
    const formatTime = (value) => {
      if (!Number.isFinite(value)) return "0:00"
      return Math.floor(value / 60) + ":" + String(Math.floor(value % 60)).padStart(2, "0")
    }
    const setButton = (button, state) => {
      if (!button) return
      const row = button.closest(".track")
      row.classList.toggle("is-playing", state === "playing")
      row.classList.toggle("is-paused", state === "paused")
      button.setAttribute("aria-label", row.dataset.title + (state === "playing" ? " 일시정지" : " 재생"))
    }
    const resetActive = () => { setButton(activeButton, "stopped"); activeButton = null }
    const clearBackdrop = () => { backdrop.pause(); backdrop.removeAttribute("src"); backdropTitle.textContent = ""; document.body.classList.remove("has-backdrop") }
    document.querySelectorAll(".track-control[data-audio]").forEach((button) => button.addEventListener("click", () => {
      if (activeButton === button) {
        if (player.paused) player.play(); else player.pause()
        return
      }
      resetActive()
      activeButton = button
      player.src = button.dataset.audio
      clearBackdrop()
      if (button.dataset.backdrop) {
        backdrop.src = button.dataset.backdrop
        backdrop.play()
        backdropTitle.textContent = button.closest(".track").dataset.title
        document.body.classList.add("has-backdrop")
      }
      player.play()
      now.textContent = button.closest(".track").dataset.title
      bar.hidden = false
    }))
    pause.addEventListener("click", () => player.paused ? player.play() : player.pause())
    stop.addEventListener("click", () => { player.pause(); player.currentTime = 0; resetActive(); clearBackdrop(); bar.hidden = true })
    player.addEventListener("loadedmetadata", () => time.textContent = formatTime(player.currentTime) + " / " + formatTime(player.duration))
    player.addEventListener("timeupdate", () => {
      const ratio = player.duration ? player.currentTime / player.duration : 0
      progressFill.style.width = (ratio * 100) + "%"
      progress.setAttribute("aria-valuenow", String(Math.round(ratio * 100)))
      time.textContent = formatTime(player.currentTime) + " / " + formatTime(player.duration)
    })
    player.addEventListener("play", () => { setButton(activeButton, "playing"); pause.classList.add("is-playing"); pause.setAttribute("aria-label", "일시정지") })
    player.addEventListener("pause", () => { if (player.currentTime) setButton(activeButton, "paused"); pause.classList.remove("is-playing"); pause.setAttribute("aria-label", "재생") })
    player.addEventListener("ended", () => { resetActive(); clearBackdrop(); pause.classList.remove("is-playing"); progressFill.style.width = "0%" })
    if (location.hash) {
      const target = document.querySelector(location.hash)
      if (target) {
        const release = target.closest("details")
        if (release) release.open = true
        target.scrollIntoView({ block: "center" })
      }
    }
  </script>

  <style>
    #listening-backdrop { position: fixed; z-index: 0; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; pointer-events: none; filter: brightness(.42) saturate(.75); transition: opacity .7s ease; }
    :global(body.has-backdrop) #listening-backdrop { opacity: 1; }
    #backdrop-title { position: fixed; z-index: 2; left: 50%; top: 50%; width: min(88vw, 780px); transform: translate(-50%, -50%); color: #fff; font-size: clamp(24px, 4vw, 52px); font-weight: 300; line-height: 1.12; text-align: center; text-shadow: 0 2px 20px rgba(0,0,0,.45); opacity: 0; pointer-events: none; transition: opacity .45s ease; }
    :global(body.has-backdrop) #backdrop-title { opacity: 1; }
    #sound-archive { position: relative; z-index: 1; width: calc(100% - 190px); max-width: 1060px; margin: 10px 0 100px 170px; transition: color .4s ease; }
    .archive-head { max-width: 650px; margin-bottom: 84px; }
    .eyebrow, .section h2, .number, .release-count, .track span:last-child { font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: #888; }
    h1 { margin: 8px 0 16px; font-weight: 300; font-size: 38px; }
    .intro { margin: 0; font-size: 18px; line-height: 1.55; }
    .section { margin: 0 0 70px; }
    .section-head { display: grid; grid-template-columns: 220px 1fr; gap: 20px; padding-bottom: 15px; border-bottom: 1px solid #111; }
    .section h2 { margin: 0; font-weight: 400; }
    .section-head p { margin: 0; font-size: 14px; color: #666; }
    .release-list, .tracklist { list-style: none; padding: 0; margin: 0; }
    .release { border-bottom: 1px solid #ddd; }
    summary { display: grid; grid-template-columns: 52px minmax(0,1fr) auto auto 24px; gap: 12px; align-items: baseline; padding: 16px 0; cursor: pointer; list-style: none; }
    summary::-webkit-details-marker { display: none; }
    summary strong { font-weight: 400; }
    .expand { text-align: right; font-size: 20px; font-weight: 300; line-height: .7; }
    details[open] .expand { transform: rotate(45deg); }
    .tracklist { padding: 0 36px 14px 64px; }
    .track { display: grid; grid-template-columns: minmax(0,1fr) minmax(130px, 220px) 26px; gap: 14px; align-items: center; padding: 7px 0; font-size: 14px; color: #666; }
    .track-meta { display: flex; justify-content: flex-end; align-items: center; gap: 12px; min-width: 0; }
    .moving-tag { display: inline-flex; align-items: center; gap: 5px; font-size: 10px; letter-spacing: .08em; line-height: 1; text-transform: uppercase; color: #777; white-space: nowrap; }
    .moving-tag.is-empty { visibility: hidden; }
    .moving-tag::before { content: ""; width: 10px; height: 7px; border: 1px solid currentColor; background: linear-gradient(90deg, currentColor 0 1px, transparent 1px 3px, currentColor 3px 4px, transparent 4px 6px, currentColor 6px 7px, transparent 7px 9px, currentColor 9px); opacity: .8; }
    .track.is-playing { color: #111; }
    .track-control, .player-actions button { display: grid; place-items: center; border: 1px solid currentColor; border-radius: 50%; background: transparent; color: currentColor; cursor: pointer; }
    .track-control { width: 22px; height: 22px; padding: 0; }
    .track-control span, .pause span { display: block; width: 0; height: 0; border-top: 5px solid transparent; border-bottom: 5px solid transparent; border-left: 7px solid currentColor; margin-left: 2px; }
    .track.is-playing .track-control span, .pause.is-playing span { width: 7px; height: 9px; border: 0; border-left: 2px solid currentColor; border-right: 2px solid currentColor; margin-left: 0; }
    .track-control:hover { color: var(--hover); }
    #player-bar { position: fixed; z-index: 5; left: 0; right: 0; bottom: 0; display: grid; grid-template-columns: minmax(180px, 1fr) auto; gap: 12px 24px; padding: 13px 18px 10px; background: #111; color: #fff; font-size: 14px; }
    .player-track { display: flex; gap: 14px; min-width: 0; }
    .now-playing { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .player-time { color: #aaa; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .player-actions { display: flex; gap: 8px; }
    .player-actions button { width: 28px; height: 28px; color: #fff; padding: 0; }
    .stop span { width: 8px; height: 8px; background: currentColor; }
    .progress { grid-column: 1 / -1; height: 2px; background: #4a4a4a; }
    .progress span { display: block; width: 0; height: 100%; background: #fff; transition: width .1s linear; }
    :global(body.has-backdrop) #sound-archive { color: #fff; text-shadow: 0 1px 12px rgba(0,0,0,.35); }
    :global(body.has-backdrop) #sound-archive, :global(body.has-backdrop) .menu, :global(body.has-backdrop) footer { opacity: 0; pointer-events: none; }
    :global(body.has-backdrop) .section-head, :global(body.has-backdrop) .release { border-color: rgba(255,255,255,.48); }
    :global(body.has-backdrop) .section h2, :global(body.has-backdrop) .section-head p, :global(body.has-backdrop) .release-count, :global(body.has-backdrop) .number, :global(body.has-backdrop) .track, :global(body.has-backdrop) .track-meta, :global(body.has-backdrop) .moving-tag { color: rgba(255,255,255,.78); }
    :global(body.has-backdrop) .track.is-playing, :global(body.has-backdrop) summary strong { color: #fff; }
    @media (max-width: 700px) { #sound-archive { width: auto; margin: 24px 16px 80px; } .archive-head { margin-bottom: 54px; } .section-head { display: block; } .section-head p { margin-top: 8px; } summary { grid-template-columns: 34px minmax(0,1fr) auto 18px; } .release-count { display: none; } .track { grid-template-columns: minmax(0,1fr) auto 26px; } .track .moving-tag { display: none; } .tracklist { padding-left: 34px; } }
  </style>
</Base>
