---
import { getCollection } from "astro:content"
import Base from "../layouts/Base.astro"

const sounds = (await getCollection("sounds", ({ data }) => !data.draft)).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
)
const sections = [
  { id: "works", title: "Sound Works", note: "Installations, spatial works, and their listening versions." },
  { id: "scores", title: "Scores & Collaborations", note: "Sound composed for fashion, performance, and shared projects." },
  { id: "archive", title: "Studies & Archive", note: "Field recordings, sketches, and independent recordings." },
]
const grouped = (id: string) => sounds.filter((sound) => sound.data.section === id)
const releases = (id: string) => {
  const items = grouped(id)
  return Array.from(new Map(items.map((item) => [item.data.project || item.data.title, item])).values()).map((lead) => ({
    title: lead.data.project || lead.data.title,
    tracks: items.filter((item) => (item.data.project || item.data.title) === (lead.data.project || lead.data.title)),
  }))
}
---

<Base title="HWANYUN — Sound" current="sound">
  <main id="sound-archive">
    <header class="archive-head">
      <p class="eyebrow">HWANYUN / LISTENING ARCHIVE</p>
      <h1>Sound</h1>
      <p class="intro">A selection of sound works, scores, and recordings. Each entry remains connected to the circumstance in which it was made.</p>
    </header>

    {sections.map((section) => (
      <section class="section" aria-labelledby={`${section.id}-title`}>
        <div class="section-head">
          <h2 id={`${section.id}-title`}>{section.title}</h2>
          <p>{section.note}</p>
        </div>
        <ol class="release-list">
          {releases(section.id).map((release, index) => (
            <li class="release">
              <details>
                <summary>
                  <span class="number">{String(index + 1).padStart(2, "0")}</span>
                  <strong>{release.title}</strong>
                  <span class="release-count">{release.tracks.length} {release.tracks.length === 1 ? "recording" : "recordings"}</span>
                  <span class="expand" aria-hidden="true">+</span>
                </summary>
                <ol class="tracklist">
                  {release.tracks.map((sound) => (
                    <li class="track">
                      <span>{sound.data.title}</span>
                      {sound.data.year && <span>{sound.data.year}</span>}
                      {sound.data.audio && <button class="play" type="button" data-audio={sound.data.audio}>Play</button>}
                    </li>
                  ))}
                </ol>
              </details>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </main>

  <audio id="archive-player" preload="metadata"></audio>
  <div id="player-bar" hidden><span class="now-playing"></span><button type="button" class="pause">Pause</button></div>

  <script is:inline>
    const player = document.getElementById("archive-player")
    const bar = document.getElementById("player-bar")
    const now = bar.querySelector(".now-playing")
    const pause = bar.querySelector(".pause")
    document.querySelectorAll(".play[data-audio]").forEach((button) => button.addEventListener("click", () => {
      player.src = button.dataset.audio
      player.play()
      now.textContent = button.parentElement.querySelector("span").textContent
      bar.hidden = false
    }))
    pause.addEventListener("click", () => player.paused ? player.play() : player.pause())
    player.addEventListener("play", () => pause.textContent = "Pause")
    player.addEventListener("pause", () => pause.textContent = "Play")
  </script>

  <style>
    #sound-archive { width: calc(100% - 190px); max-width: 1060px; margin: 10px 0 100px 170px; }
    .archive-head { max-width: 650px; margin-bottom: 84px; }
    .eyebrow, .section h2, .number, .release-count, .track span:last-child { font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: #888; }
    h1 { margin: 8px 0 16px; font-weight: 300; font-size: 38px; }
    .intro { margin: 0; font-size: 18px; line-height: 1.55; }
    .section { margin: 0 0 70px; }
    .section-head { display: grid; grid-template-columns: 220px 1fr; gap: 20px; padding-bottom: 15px; border-bottom: 1px solid #111; }
    .section h2 { margin: 0; font-weight: 400; }
    .section-head p { margin: 0; font-size: 14px; color: #666; }
    .release-list, .tracklist { list-style: none; padding: 0; margin: 0; }
    .release { border-bottom: 1px solid #ddd; }
    summary { display: grid; grid-template-columns: 52px minmax(0,1fr) 110px 24px; gap: 12px; align-items: baseline; padding: 16px 0; cursor: pointer; list-style: none; }
    summary::-webkit-details-marker { display: none; }
    summary strong { font-weight: 400; }
    .expand { text-align: right; font-size: 20px; font-weight: 300; line-height: .7; }
    details[open] .expand { transform: rotate(45deg); }
    .tracklist { padding: 0 36px 14px 64px; }
    .track { display: grid; grid-template-columns: minmax(0,1fr) auto 42px; gap: 20px; align-items: baseline; padding: 6px 0; font-size: 14px; color: #666; }
    .play { border: 0; padding: 0; background: none; color: inherit; font: inherit; cursor: pointer; }
    .play:hover { color: var(--hover); }
    #player-bar { position: fixed; z-index: 5; left: 0; right: 0; bottom: 0; display: flex; justify-content: space-between; gap: 20px; padding: 14px 18px; background: #111; color: #fff; font-size: 14px; }
    #player-bar button { border: 0; background: none; color: inherit; font: inherit; cursor: pointer; }
    @media (max-width: 700px) { #sound-archive { width: auto; margin: 24px 16px 80px; } .archive-head { margin-bottom: 54px; } .section-head { display: block; } .section-head p { margin-top: 8px; } summary { grid-template-columns: 34px minmax(0,1fr) 18px; } .release-count { display: none; } .tracklist { padding-left: 34px; } }
  </style>
</Base>
