---
const { title = "HWANYUN", current = "" } = Astro.props
const nav = [
  { label: "Works", href: "/works", key: "works" },
  { label: "Sound", href: "/sound", key: "sound" },
  { label: "Bio", href: "/cv", key: "bio" },
  { label: "Contact", href: "/contact", key: "contact" },
]
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0b0d" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <slot name="menu">
      <nav class="menu">
        <div class="name"><a href="/">HWANYUN</a></div>
        {
          nav.map((n) => (
            <a href={n.href} class={current === n.key ? "current" : ""}>
              {n.label}
            </a>
          ))
        }
      </nav>
    </slot>
    <slot />
    <div class="cursor-dot" aria-hidden="true"></div>
    <footer>COPYRIGHT © 2014 HWANYUN. All rights reserved.</footer>

    <script is:inline>
      ;(function () {
        if (!window.matchMedia("(pointer: fine)").matches) return
        var dot = document.querySelector(".cursor-dot")
        if (!dot) return
        window.addEventListener("pointermove", function (event) {
          dot.style.transform = "translate3d(" + event.clientX + "px," + event.clientY + "px,0) translate(-50%,-50%)"
          dot.classList.add("is-visible")
        })
        document.addEventListener("mouseleave", function () { dot.classList.remove("is-visible") })
      })()
    </script>

    <style is:global>
      :root {
        --w-1col: 380px;
        --w-2col: 460px;
        --w-3col: 540px;
        --gap: 10px;
        /* 카테고리 간 본문 폭 통일 (Works/Sound/Bio) */
        --content-w: 900px;
        --hover: #00f;
        --sans: "Noto Sans KR", sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      body {
        font-family: var(--sans);
        font-weight: 300;
        font-size: 18px;
        line-height: 1.35;
        color: #000;
        background: #fff;
        margin: 0;
        padding: 0;
        word-break: keep-all;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a { color: #000; text-decoration: none; }
      a:hover { color: var(--hover); }

      .cursor-dot { display: none; }
      @media (pointer: fine) {
        html, body, a, button, input, textarea, select, video, iframe { cursor: none !important; }
        .cursor-dot {
          position: fixed;
          top: 0;
          left: 0;
          z-index: 100;
          display: block;
          width: 14px;
          height: 14px;
          border-radius: 50%;
          background: #fff;
          mix-blend-mode: difference;
          pointer-events: none;
          opacity: 0;
          transition: opacity 0.18s ease;
        }
        .cursor-dot.is-visible { opacity: 1; }
      }

      .menu {
        float: left;
        width: 140px;
        margin: 10px 0 0 10px;
        line-height: 1.5;
      }
      .menu .name { font-weight: 500; margin-bottom: 12px; }
      .menu a { display: block; }
      .menu a:hover { border-bottom: 1px solid var(--hover); width: fit-content; }
      .menu a.current { border-bottom: 1px solid #000; width: fit-content; }

      footer {
        clear: both;
        padding: 60px 10px 30px;
        font-size: 13px;
        color: #888;
      }

      @media (max-width: 700px) {
        .menu { float: none; width: auto; padding: 0 10px; }
      }
    </style>
  </body>
</html>
